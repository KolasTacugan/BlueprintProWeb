@model IEnumerable<BlueprintProWeb.Models.Project>

@{
    ViewData["Title"] = "My Projects";
    Layout = "~/Views/Shared/_ClientSharedLayout.cshtml";
}

@section Styles {
    <style>
        body::before {
            background: url("/images/BPP_Dashboard_BG.png") center/cover no-repeat !important;
            opacity: 0.1 !important;
        }

        body {
            background: #F1F7F9 !important;
            overflow-y: auto !important;
            height: auto !important;
            font-family: 'Raleway', sans-serif !important;
        }

        main.container {
            margin-left: 270px;
            margin-top: 70px;
            padding: 1.5rem;
            padding-top: 2rem;
            max-width: calc(100% - 270px);
            transition: margin-left 0.4s ease, max-width 0.4s ease;
        }

        .sidebar.collapsed ~ * main.container,
        body:has(.sidebar.collapsed) main.container {
            margin-left: 85px;
            max-width: calc(100% - 85px);
        }

        /* ── Page Header (unified) ─────────── */
        .page-header {
            margin-bottom: 1.75rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid #f0f4f8;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
        }

        .page-header-left {
            display: flex;
            align-items: center;
            gap: 0.95rem;
        }

        .page-header-icon {
            width: 46px;
            height: 46px;
            border-radius: 13px;
            background: rgba(13, 60, 128, 0.08);
            color: #0D3C80;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
            flex-shrink: 0;
        }

        .page-title {
            font-weight: 600;
            font-size: 1.6rem;
            letter-spacing: -0.3px;
            color: #091635;
            margin: 0;
            line-height: 1.2;
        }

        .page-header-icon .material-symbols-rounded {
            font-size: 1.5rem;
        }

        .page-subtitle {
            font-size: 0.85rem;
            font-weight: 500;
            color: #8b97a8;
            margin-top: 0.2rem;
        }

        .purchased-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: #F8FAFC;
            color: #344EAD;
            border: 1.5px solid #E2E8F0;
            border-radius: 10px;
            padding: 0.65rem 1.15rem;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.2s ease;
            cursor: pointer;
        }

        .purchased-btn:hover {
            background: #F1F7F9;
            border-color: #344EAD;
            color: #344EAD;
            transform: translateY(-1px);
        }

        .purchased-btn i {
            font-size: 0.85rem;
        }

        /* ── Projects Grid ────────────────────────────────────── */
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.25rem;
        }

        .project-card {
            background: #FFFFFF;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(7, 23, 68, 0.07);
            border: 1px solid #eef2f7;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: all 0.25s ease;
        }

        .project-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(52, 78, 173, 0.12);
            border-color: rgba(52, 78, 173, 0.2);
        }

        .project-image-wrap {
            position: relative;
            width: 100%;
            height: 170px;
            overflow: hidden;
            background: #F1F7F9;
        }

        .project-image-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.35s ease;
        }

        .project-card:hover .project-image-wrap img {
            transform: scale(1.03);
        }

        .project-status-pill {
            position: absolute;
            top: 0.85rem;
            left: 0.85rem;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.35rem 0.75rem;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            backdrop-filter: blur(8px);
        }

        .project-status-pill i {
            font-size: 0.55rem;
        }

        .status-ongoing {
            background: rgba(59, 130, 246, 0.92);
            color: #FFFFFF;
        }

        .status-review {
            background: rgba(245, 158, 11, 0.92);
            color: #FFFFFF;
        }

        .status-compliance {
            background: rgba(139, 92, 246, 0.92);
            color: #FFFFFF;
        }

        .status-finalization {
            background: rgba(16, 185, 129, 0.92);
            color: #FFFFFF;
        }

        .status-finished {
            background: rgba(34, 197, 94, 0.92);
            color: #FFFFFF;
        }

        .project-body {
            padding: 1.25rem 1.35rem 1.1rem;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .project-title {
            font-weight: 700;
            font-size: 1.1rem;
            color: #1a202c;
            margin: 0 0 0.85rem;
            letter-spacing: -0.2px;
            line-height: 1.3;
            display: -webkit-box;
            -webkit-line-clamp: 1;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .project-meta {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.65rem;
            margin-bottom: 1rem;
        }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            padding: 0.6rem 0.75rem;
            background: #F8FAFC;
            border-radius: 8px;
            border-left: 3px solid #344EAD;
        }

        .meta-icon {
            width: 28px;
            height: 28px;
            background: linear-gradient(135deg, #344EAD 0%, #2563EB 100%);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #FFFFFF;
            font-size: 0.75rem;
            flex-shrink: 0;
        }

        .meta-content {
            display: flex;
            flex-direction: column;
            gap: 0.1rem;
            min-width: 0;
        }

        .meta-label {
            font-size: 0.65rem;
            font-weight: 700;
            color: #64748B;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .meta-value {
            font-size: 0.82rem;
            font-weight: 600;
            color: #1a202c;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .meta-value.architect-link {
            color: #344EAD;
            cursor: pointer;
            border-bottom: 1px dashed transparent;
            transition: all 0.2s ease;
            text-decoration: none;
        }

        .meta-value.architect-link:hover {
            color: #2563EB;
            border-bottom-color: #2563EB;
            text-decoration: none;
        }

        .project-actions {
            display: flex;
            gap: 0.6rem;
            margin-top: auto;
            padding-top: 1rem;
            border-top: 1px solid #f0f4f8;
        }

        .track-btn {
            flex: 1;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            background: linear-gradient(135deg, #344EAD 0%, #2563EB 100%);
            color: #FFFFFF;
            border: none;
            border-radius: 8px;
            padding: 0.7rem 1.1rem;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-decoration: none;
            transition: all 0.2s ease;
            box-shadow: 0 2px 4px rgba(52, 78, 173, 0.2);
        }

        .track-btn:hover {
            background: linear-gradient(135deg, #2563EB 0%, #1d4ed8 100%);
            transform: translateY(-1px);
            box-shadow: 0 4px 10px rgba(52, 78, 173, 0.3);
            color: #FFFFFF;
            text-decoration: none;
        }

        /* ── Empty State ──────────────────────────────────────── */
        .empty-state {
            background: #FFFFFF;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(7, 23, 68, 0.07);
            border: 1px solid #eef2f7;
            text-align: center;
            padding: 4rem 2rem;
        }

        .empty-state-icon {
            width: 72px;
            height: 72px;
            background: rgba(52, 78, 173, 0.08);
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #344EAD;
            font-size: 1.75rem;
            margin-bottom: 1.25rem;
        }

        .empty-state-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: #1a202c;
            margin-bottom: 0.35rem;
            letter-spacing: -0.2px;
        }

        .empty-state-subtitle {
            font-size: 0.875rem;
            color: #64748B;
            line-height: 1.55;
            max-width: 380px;
            margin: 0 auto;
        }

        /* ── Modals ───────────────────────────────────────────── */
        .modal-content {
            border-radius: 16px;
            border: 1px solid #eef2f7;
            box-shadow: 0 20px 60px rgba(7, 23, 68, 0.2);
            overflow: hidden;
        }

        .modal-header {
            background: linear-gradient(135deg, #071744 0%, #344EAD 100%);
            color: #FFFFFF;
            border-bottom: none;
            padding: 1.25rem 1.5rem;
        }

        .modal-title {
            font-weight: 700;
            font-size: 1rem;
            display: flex;
            align-items: center;
            gap: 0.55rem;
            letter-spacing: -0.1px;
        }

        .modal-title i {
            font-size: 0.95rem;
        }

        .btn-close {
            filter: invert(1);
            opacity: 0.85;
        }

        .modal-body {
            padding: 1.75rem;
        }

        /* ── Profile Card in Modal ────────────────────────────── */
        .profile-main-card {
            background: #F8FAFC;
            border-radius: 12px;
            border: 1px solid #eef2f7;
            padding: 1.25rem;
        }

        .profile-info {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.25rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid #eef2f7;
        }

        .avatar img {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #FFFFFF;
            box-shadow: 0 4px 12px rgba(52, 78, 173, 0.15);
        }

        .architect-name {
            color: #1a202c;
            font-weight: 700;
            font-size: 1.15rem;
            margin: 0 0 0.25rem;
            letter-spacing: -0.2px;
        }

        .profile-info .text-muted {
            color: #64748B !important;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            gap: 0.45rem;
            margin-top: 0.2rem;
        }

        .profile-info .text-muted i {
            width: 14px;
            color: #344EAD;
            font-size: 0.75rem;
        }

        .profile-detail-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.6rem;
        }

        .profile-detail-row {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.65rem 0.85rem;
            background: #FFFFFF;
            border-radius: 8px;
            border-left: 3px solid #344EAD;
        }

        .profile-detail-row i {
            width: 28px;
            height: 28px;
            background: linear-gradient(135deg, #344EAD 0%, #2563EB 100%);
            color: #FFFFFF;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            flex-shrink: 0;
        }

        .profile-detail-row .detail-label {
            font-size: 0.68rem;
            font-weight: 700;
            color: #64748B;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: block;
        }

        .profile-detail-row .detail-value {
            font-size: 0.85rem;
            font-weight: 600;
            color: #1a202c;
        }

        .archi-cred {
            color: #344EAD;
            font-weight: 600;
            text-decoration: none;
            border-bottom: 1px dashed transparent;
            transition: all 0.2s ease;
        }

        .archi-cred:hover {
            color: #2563EB;
            border-bottom-color: #2563EB;
            text-decoration: none;
        }

        /* ── Purchased Blueprints Modal ───────────────────────── */
        .purchased-blueprint-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem 1.15rem;
            background: #F8FAFC;
            border: 1px solid #eef2f7;
            border-radius: 12px;
            margin-bottom: 0.85rem;
            transition: all 0.2s ease;
        }

        .purchased-blueprint-item:last-child {
            margin-bottom: 0;
        }

        .purchased-blueprint-item:hover {
            border-color: rgba(52, 78, 173, 0.2);
            box-shadow: 0 2px 8px rgba(52, 78, 173, 0.06);
        }

        .purchased-blueprint-item img {
            width: 90px;
            height: 70px;
            object-fit: cover;
            border-radius: 8px;
            border: 1px solid #eef2f7;
            flex-shrink: 0;
        }

        .blueprint-info {
            flex: 1;
            min-width: 0;
        }

        .blueprint-info h5 {
            margin: 0 0 0.35rem;
            font-size: 0.95rem;
            font-weight: 700;
            color: #1a202c;
            letter-spacing: -0.1px;
        }

        .blueprint-info p {
            margin: 0.15rem 0;
            font-size: 0.8rem;
            color: #64748b;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .blueprint-info p i {
            width: 12px;
            color: #344EAD;
            font-size: 0.7rem;
        }

        /* ── Responsive ───────────────────────────────────────── */
        @@media (max-width: 1200px) {
            .projects-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 768px) {
            main.container {
                margin-left: 0 !important;
                margin-top: 100px;
                max-width: 100% !important;
                padding: 1rem;
                padding-top: 2rem;
            }

            .page-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }

            .page-title {
                font-size: 1.4rem;
            }

            .project-meta {
                grid-template-columns: 1fr;
            }

            .modal-body {
                padding: 1.25rem;
            }
        }
    </style>
}

<div>
    <div class="page-header">
        <div class="page-header-left">
            <div class="page-header-icon">
                <span class="material-symbols-rounded">note_stack</span>
            </div>
            <div>
                <h1 class="page-title">My Projects</h1>
                <div class="page-subtitle">Track your active construction projects</div>
            </div>
        </div>
        <button type="button" class="purchased-btn" id="purchasedBtn">
            <i class="fas fa-folder-open"></i>
            Purchased Blueprints
        </button>
    </div>

    @if (Model.Any())
    {
        <div class="projects-grid">
            @foreach (var project in Model)
            {
                var statusClass = project.project_Status switch
                {
                    "Ongoing" => "status-ongoing",
                    "Review" => "status-review",
                    "Compliance" => "status-compliance",
                    "Finalization" => "status-finalization",
                    "Finished" => "status-finished",
                    _ => "status-ongoing"
                };

                <div class="project-card">
                    <div class="project-image-wrap">
                        <img src="@(project.Blueprint.blueprintImage.StartsWith("/uploads")
                                    ? project.Blueprint.blueprintImage
                                    : Url.Content("~/images/" + project.Blueprint.blueprintImage))"
                             asp-append-version="true"
                             alt="@project.project_Title" />
                        <span class="project-status-pill @statusClass">
                            <i class="fas fa-circle"></i>
                            @project.project_Status
                        </span>
                    </div>

                    <div class="project-body">
                        <h3 class="project-title">@project.project_Title</h3>

                        <div class="project-meta">
                            <div class="meta-item">
                                <div class="meta-icon">
                                    <i class="fas fa-peso-sign"></i>
                                </div>
                                <div class="meta-content">
                                    <span class="meta-label">Budget</span>
                                    <span class="meta-value">₱@project.project_Budget</span>
                                </div>
                            </div>
                            <div class="meta-item">
                                <div class="meta-icon">
                                    <i class="fas fa-drafting-compass"></i>
                                </div>
                                <div class="meta-content">
                                    <span class="meta-label">Architect</span>
                                    <a href="#"
                                       class="meta-value architect-link"
                                       data-client-id="@project.Architect.Id">
                                        @project.Architect.user_fname @project.Architect.user_lname
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="project-actions">
                            <a asp-controller="ClientInterface"
                               asp-action="ProjectTracker"
                               asp-route-id="@project.blueprint_Id"
                               class="track-btn">
                                <i class="fas fa-eye"></i>
                                Track Project
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="fas fa-project-diagram"></i>
            </div>
            <div class="empty-state-title">No Projects Yet</div>
            <div class="empty-state-subtitle">
                Your active projects will appear here once you start working with architects.
            </div>
        </div>
    }
</div>

<!-- Architect Profile Modal -->
<div class="modal fade" id="architectProfileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-user-circle"></i>
                    Architect Profile
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="profile-main-card">
                    <div class="profile-info">
                        <div class="avatar">
                            <img id="architectProfilePhoto" src="~/images/profile.jpg" alt="Avatar">
                        </div>
                        <div class="user-details">
                            <h3 id="architectProfileName" class="architect-name"></h3>
                            <div id="architectProfileEmail" class="text-muted">
                                <i class="fas fa-envelope"></i>
                                <span></span>
                            </div>
                            <div id="architectProfilePhone" class="text-muted">
                                <i class="fas fa-phone"></i>
                                <span></span>
                            </div>
                        </div>
                    </div>

                    <div class="profile-detail-grid">
                        <div class="profile-detail-row">
                            <i class="fas fa-id-card"></i>
                            <div>
                                <span class="detail-label">License No</span>
                                <div class="detail-value" id="architectProfileLicense"></div>
                            </div>
                        </div>
                        <div class="profile-detail-row">
                            <i class="fas fa-palette"></i>
                            <div>
                                <span class="detail-label">Style</span>
                                <div class="detail-value" id="architectProfileStyle"></div>
                            </div>
                        </div>
                        <div class="profile-detail-row">
                            <i class="fas fa-star"></i>
                            <div>
                                <span class="detail-label">Specialization</span>
                                <div class="detail-value" id="architectProfileSpecialization"></div>
                            </div>
                        </div>
                        <div class="profile-detail-row">
                            <i class="fas fa-map-marker-alt"></i>
                            <div>
                                <span class="detail-label">Location</span>
                                <div class="detail-value" id="architectProfileLocation"></div>
                            </div>
                        </div>
                        <div class="profile-detail-row" id="credentialsRow">
                            <i class="fas fa-file-pdf"></i>
                            <div>
                                <span class="detail-label">Credentials</span>
                                <div class="detail-value">
                                    <a id="architectProfileCredentials" href="#" target="_blank" class="archi-cred">View Credentials</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Purchased Blueprints Modal -->
<div class="modal fade" id="purchasedBlueprintsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-folder-open"></i>
                    My Purchased Blueprints
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="purchasedBlueprintsList">
                    <!-- Blueprints will be loaded here -->
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const sidebar = document.querySelector('.sidebar');
            const sidebarToggler = document.querySelector('.sidebar-toggler');
            const mainContent = document.querySelector('main.container');

            function adjustMainContent() {
                if (sidebar && mainContent) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '85px';
                        mainContent.style.maxWidth = 'calc(100% - 85px)';
                    } else {
                        mainContent.style.marginLeft = '270px';
                        mainContent.style.maxWidth = 'calc(100% - 270px)';
                    }
                }
            }

            adjustMainContent();

            if (sidebarToggler) {
                sidebarToggler.addEventListener('click', function () {
                    setTimeout(adjustMainContent, 50);
                });
            }

            // Architect profile modal trigger
            const architectLinks = document.querySelectorAll('.architect-link');

            architectLinks.forEach(link => {
                link.addEventListener('click', async function (e) {
                    e.preventDefault();
                    const architectId = this.getAttribute('data-client-id');

                    try {
                        const res = await fetch(`/ClientInterface/GetArchitectProfile?id=${architectId}`);
                        if (!res.ok) throw new Error('Failed to fetch architect profile');

                        const data = await res.json();

                        document.getElementById('architectProfileName').textContent = data.fullName;
                        document.getElementById('architectProfileEmail').querySelector('span').textContent = data.email || 'No email provided';
                        document.getElementById('architectProfilePhone').querySelector('span').textContent = data.phone || 'No phone provided';
                        document.getElementById('architectProfilePhoto').src = data.photo;
                        document.getElementById('architectProfileLicense').textContent = data.license || 'N/A';
                        document.getElementById('architectProfileStyle').textContent = data.style || 'N/A';
                        document.getElementById('architectProfileSpecialization').textContent = data.specialization || 'N/A';
                        document.getElementById('architectProfileLocation').textContent = data.location || 'N/A';

                        const credentialsLink = document.getElementById('architectProfileCredentials');
                        const credentialsRow = document.getElementById('credentialsRow');
                        if (data.credentialsFile) {
                            credentialsLink.href = data.credentialsFile;
                            credentialsRow.style.display = 'flex';
                        } else {
                            credentialsRow.style.display = 'none';
                        }

                        const modal = new bootstrap.Modal(document.getElementById('architectProfileModal'));
                        modal.show();
                    } catch (err) {
                        console.error(err);
                        alert('Failed to load architect information.');
                    }
                });
            });

            // Purchased Blueprints Modal Trigger
            const purchasedBtn = document.getElementById('purchasedBtn');
            if (purchasedBtn) {
                purchasedBtn.addEventListener('click', async function (e) {
                    e.preventDefault();

                    try {
                        const res = await fetch('/ClientInterface/GetPurchasedBlueprints');
                        if (!res.ok) throw new Error('Failed to fetch purchased blueprints');

                        const blueprints = await res.json();

                        const container = document.getElementById('purchasedBlueprintsList');
                        container.innerHTML = '';

                        if (blueprints.length === 0) {
                            container.innerHTML = `
                                <div class="empty-state" style="padding: 2.5rem 1rem; box-shadow: none; border: none;">
                                    <div class="empty-state-icon">
                                        <i class="fas fa-folder-open"></i>
                                    </div>
                                    <div class="empty-state-title">No Purchased Blueprints</div>
                                    <div class="empty-state-subtitle">
                                        You haven't purchased any blueprints yet. Visit the marketplace to browse available options.
                                    </div>
                                </div>
                            `;
                        } else {
                            blueprints.forEach(bp => {
                                const item = document.createElement('div');
                                item.className = 'purchased-blueprint-item';
                                const imageSrc = bp.image ? `/images/${bp.image}` : '/images/placeholder-blueprint.png';
                                item.innerHTML = `
                                    <img src="${imageSrc}" alt="${bp.name}" />
                                    <div class="blueprint-info">
                                        <h5>${bp.name}</h5>
                                        <p><i class="fas fa-palette"></i>Style: ${bp.style || 'N/A'}</p>
                                        <p><i class="fas fa-peso-sign"></i>Price: ₱${bp.price ? bp.price.toLocaleString() : 'N/A'}</p>
                                    </div>
                                `;
                                container.appendChild(item);
                            });
                        }

                        const modal = new bootstrap.Modal(document.getElementById('purchasedBlueprintsModal'));
                        modal.show();
                    } catch (err) {
                        console.error(err);
                        alert('Failed to load purchased blueprints.');
                    }
                });
            }
        });
    </script>
}
