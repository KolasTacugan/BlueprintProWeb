@model BlueprintProWeb.ViewModels.BlueprintViewModel

@{
    ViewData["Title"] = "Add Blueprints";
    Layout = "~/Views/Shared/_ArchitectSharedLayout.cshtml";
}

@section Styles {
    <style>
        body::before {
            background: url("/images/BPP_Dashboard_BG.png") center/cover no-repeat !important;
            opacity: 0.1 !important;
        }

        body {
            background: #F1F7F9 !important;
            overflow-y: auto !important;
            height: auto !important;
            font-family: 'Raleway', sans-serif !important;
        }

        main.container {
            margin-left: 300px;
            margin-top: 120px;
            padding: 1.5rem;
            padding-top: 4rem;
            max-width: calc(100% - 320px);
            width: calc(100% - 320px);
            transition: margin-left 0.4s ease, max-width 0.4s ease, width 0.4s ease;
        }

        .sidebar.collapsed ~ * main.container,
        body:has(.sidebar.collapsed) main.container {
            margin-left: 110px;
            max-width: calc(100% - 130px);
            width: calc(100% - 130px);
        }

        /* ── Page Header (matches dashboard-greeting) ─────────── */
        .page-header {
            color: #1a202c;
            margin-bottom: 1.5rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid #e8edf5;
        }

        .page-title {
            font-weight: 700;
            font-size: 1.75rem;
            letter-spacing: -0.3px;
            color: #1a202c;
            margin: 0;
        }

        .page-subtitle {
            font-size: 0.9rem;
            font-weight: 400;
            color: #94a3b8;
            margin-top: 0.3rem;
        }

        /* ── Category Tabs ────────────────────────────────────── */
        .category-tabs-container {
            background: #FFFFFF;
            border-radius: 12px;
            padding: 0.45rem;
            margin-bottom: 1.25rem;
            box-shadow: 0 2px 12px rgba(7, 23, 68, 0.07);
            border: 1px solid #eef2f7;
            display: inline-flex;
        }

        .nav-tabs {
            border: none;
            gap: 0.25rem;
            flex-wrap: nowrap;
        }

        .nav-tabs .nav-item .nav-link {
            border: none;
            border-radius: 8px;
            padding: 0.65rem 1.2rem;
            color: #64748B;
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.2s ease;
            background: transparent;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .nav-tabs .nav-item .nav-link i {
            font-size: 0.85rem;
        }

        .nav-tabs .nav-item .nav-link:hover {
            background: rgba(52, 78, 173, 0.06);
            color: #344EAD;
        }

        .nav-tabs .nav-item .nav-link.active {
            background: linear-gradient(135deg, #344EAD 0%, #2563EB 100%);
            color: #FFFFFF;
            box-shadow: 0 2px 8px rgba(52, 78, 173, 0.25);
        }

        /* ── Form Container ───────────────────────────────────── */
        .form-container {
            background: #FFFFFF;
            border-radius: 14px;
            box-shadow: 0 2px 12px rgba(7, 23, 68, 0.07);
            border: 1px solid #eef2f7;
            padding: 2rem 2.25rem 2.25rem;
            width: 100%;
        }

        .form-section-title {
            display: flex;
            align-items: center;
            gap: 0.55rem;
            color: #1a202c;
            font-weight: 700;
            font-size: 0.95rem;
            letter-spacing: -0.1px;
            margin-bottom: 1.25rem;
            padding-bottom: 0.9rem;
            border-bottom: 1px solid #f0f4f8;
        }

        .form-section-title .section-icon {
            width: 28px;
            height: 28px;
            background: rgba(52, 78, 173, 0.08);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #344EAD;
            font-size: 0.85rem;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem 2.25rem;
            margin-bottom: 1.5rem;
        }

        .form-grid-full {
            grid-column: 1 / -1;
        }

        .form-group {
            display: flex;
            flex-direction: column;
        }

        .control-label {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            font-size: 0.72rem;
            font-weight: 700;
            color: #64748B;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.55rem;
        }

        .control-label i {
            color: #344EAD;
            font-size: 0.72rem;
        }

        .form-control {
            border: 1.5px solid #E2E8F0;
            border-radius: 10px;
            padding: 0.75rem 0.95rem;
            font-family: 'Raleway', sans-serif;
            font-size: 0.88rem;
            color: #1a202c;
            background: #F8FAFC;
            transition: all 0.2s ease;
            width: 100%;
        }

        .form-control:focus {
            border-color: #344EAD;
            background: #FFFFFF;
            box-shadow: 0 0 0 3px rgba(52, 78, 173, 0.12);
            outline: none;
        }

        .form-control:hover:not(:focus) {
            border-color: #CBD5E0;
        }

        .bp-desc {
            height: 130px;
            resize: vertical;
            word-wrap: break-word;
        }

        /* ── File Upload Zone ─────────────────────────────────── */
        .file-upload-wrap {
            position: relative;
        }

        .file-upload-wrap input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
            z-index: 2;
        }

        .file-upload-zone {
            border: 2px dashed #CBD5E0;
            background: #F8FAFC;
            border-radius: 10px;
            padding: 1.75rem 1rem;
            text-align: center;
            transition: all 0.2s ease;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.65rem;
        }

        .file-upload-wrap:hover .file-upload-zone {
            border-color: #344EAD;
            background: rgba(52, 78, 173, 0.04);
        }

        .file-upload-zone.has-file {
            border-style: solid;
            border-color: #344EAD;
            background: rgba(52, 78, 173, 0.04);
        }

        .file-upload-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: linear-gradient(135deg, #344EAD 0%, #2563EB 100%);
            color: #FFFFFF;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
            box-shadow: 0 2px 8px rgba(52, 78, 173, 0.25);
        }

        .file-upload-title {
            font-size: 0.88rem;
            font-weight: 700;
            color: #1a202c;
            margin: 0;
        }

        .file-upload-title .accent {
            color: #344EAD;
        }

        .file-upload-hint {
            font-size: 0.73rem;
            color: #94a3b8;
            margin: 0;
        }

        .file-name-display {
            font-size: 0.8rem;
            font-weight: 600;
            color: #344EAD;
            display: none;
            align-items: center;
            gap: 0.4rem;
        }

        .file-name-display i {
            font-size: 0.75rem;
        }

        .file-upload-zone.has-file .file-name-display {
            display: inline-flex;
        }

        .file-upload-zone.has-file .file-upload-title,
        .file-upload-zone.has-file .file-upload-hint {
            display: none;
        }

        /* Select dropdown */
        select.form-control {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%23344EAD' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.8' d='m6 8 4 4 4-4'/%3e%3c/svg%3e");
            background-position: right 0.75rem center;
            background-repeat: no-repeat;
            background-size: 1.3em 1.3em;
            padding-right: 2.5rem;
            appearance: none;
        }

        /* ── Submit Button ────────────────────────────────────── */
        .form-footer {
            margin-top: 0.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid #f0f4f8;
            display: flex;
            justify-content: flex-end;
            gap: 0.75rem;
        }

        .add-bp {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.55rem;
            background: linear-gradient(135deg, #344EAD 0%, #2563EB 100%);
            color: #FFFFFF;
            border: none;
            border-radius: 10px;
            padding: 0.8rem 2rem;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.2s ease;
            box-shadow: 0 2px 8px rgba(52, 78, 173, 0.25);
            cursor: pointer;
        }

        .add-bp:hover {
            background: linear-gradient(135deg, #2563EB 0%, #1d4ed8 100%);
            transform: translateY(-1px);
            box-shadow: 0 4px 14px rgba(52, 78, 173, 0.35);
            color: #FFFFFF;
        }

        .add-bp:active {
            transform: translateY(0);
        }

        /* Validation message */
        .text-danger {
            color: #DC2626 !important;
            font-size: 0.73rem;
            font-weight: 500;
            margin-top: 0.35rem;
            display: block;
        }

        /* ── Responsive ───────────────────────────────────────── */
        @@media (max-width: 1200px) {
            .form-grid {
                gap: 1.25rem 1.75rem;
            }
        }

        @@media (max-width: 992px) {
            .form-grid {
                grid-template-columns: 1fr;
                gap: 1.25rem;
            }
        }

        @@media (max-width: 768px) {
            main.container {
                margin-left: 0 !important;
                margin-top: 100px;
                max-width: 100% !important;
                width: 100% !important;
                padding: 1rem;
                padding-top: 2rem;
            }

            .page-title {
                font-size: 1.4rem;
            }

            .form-container {
                padding: 1.5rem;
            }

            .category-tabs-container {
                width: 100%;
                display: flex;
            }

            .nav-tabs {
                width: 100%;
            }

            .nav-tabs .nav-item {
                flex: 1;
            }

            .nav-tabs .nav-item .nav-link {
                justify-content: center;
            }

            .form-footer {
                justify-content: stretch;
            }

            .add-bp {
                width: 100%;
            }
        }

        @@media (max-width: 576px) {
            .form-container {
                padding: 1.25rem;
            }

            .page-title {
                font-size: 1.25rem;
            }
        }
    </style>
}

<div>
    <div class="page-header">
        <h1 class="page-title">Add Blueprints</h1>
        <div class="page-subtitle">Upload new blueprints to expand your portfolio</div>
    </div>

    <div class="category-tabs-container">
        <ul class="nav nav-tabs" id="blueprintTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="marketplace-tab"
                        data-bs-toggle="tab" data-bs-target="#marketplace"
                        type="button" role="tab" aria-controls="marketplace" aria-selected="true">
                    <i class="fas fa-store"></i>
                    For Marketplace
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="project-tab"
                        data-bs-toggle="tab" data-bs-target="#project"
                        type="button" role="tab" aria-controls="project" aria-selected="false">
                    <i class="fas fa-project-diagram"></i>
                    For Project
                </button>
            </li>
        </ul>
    </div>

    <!-- Tabs Content -->
    <div class="tab-content" id="blueprintTabsContent">

        <!-- Marketplace Form -->
        <div class="tab-pane fade show active" id="marketplace" role="tabpanel" aria-labelledby="marketplace-tab">
            <div class="form-container">
                <div class="form-section-title">
                    <span class="section-icon"><i class="fas fa-store"></i></span>
                    Marketplace Blueprint Details
                </div>
                <form asp-action="AddBlueprints" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-grid">
                        <div class="form-group form-grid-full">
                            <label asp-for="BlueprintImage" class="control-label">
                                <i class="fas fa-image"></i>
                                Blueprint File
                            </label>
                            <div class="file-upload-wrap">
                                <input asp-for="BlueprintImage" type="file" accept="image/*" required data-upload-target="marketplace" />
                                <div class="file-upload-zone" data-upload-zone="marketplace">
                                    <div class="file-upload-icon">
                                        <i class="fas fa-cloud-upload-alt"></i>
                                    </div>
                                    <p class="file-upload-title">
                                        Drop your blueprint here or <span class="accent">click to browse</span>
                                    </p>
                                    <p class="file-upload-hint">PNG, JPG up to 10MB</p>
                                    <span class="file-name-display">
                                        <i class="fas fa-file-image"></i>
                                        <span data-file-name="marketplace"></span>
                                    </span>
                                </div>
                            </div>
                            <span asp-validation-for="BlueprintImage" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="blueprintName" class="control-label">
                                <i class="fas fa-heading"></i>
                                Blueprint Name
                            </label>
                            <input asp-for="blueprintName" class="form-control" placeholder="e.g. Modern Bungalow Layout" />
                            <span asp-validation-for="blueprintName" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="blueprintStyle" class="control-label">
                                <i class="fas fa-palette"></i>
                                Style
                            </label>
                            <select asp-for="blueprintStyle" class="form-control">
                                <option value="Modern">Modern</option>
                                <option value="Traditional">Traditional</option>
                                <option value="Contemporary">Contemporary</option>
                                <option value="Minimalist">Minimalist</option>
                            </select>
                            <span asp-validation-for="blueprintStyle" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="blueprintPrice" class="control-label">
                                <i class="fas fa-peso-sign"></i>
                                Price (in Pesos)
                            </label>
                            <input asp-for="blueprintPrice" type="text" class="form-control price-input" placeholder="0" inputmode="numeric" autocomplete="off" />
                            <span asp-validation-for="blueprintPrice" class="text-danger"></span>
                        </div>

                        <div class="form-group form-grid-full">
                            <label asp-for="blueprintDescription" class="control-label">
                                <i class="fas fa-align-left"></i>
                                Description
                            </label>
                            <textarea asp-for="blueprintDescription" class="bp-desc form-control" placeholder="Describe the key features and style of your blueprint..."></textarea>
                            <span asp-validation-for="blueprintDescription" class="text-danger"></span>
                        </div>
                    </div>

                    <input type="hidden" asp-for="blueprintIsForSale" value="true" />
                    <div class="form-footer">
                        <button type="submit" class="add-bp">
                            <i class="fas fa-cloud-upload-alt"></i>
                            Upload to Marketplace
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Project Form -->
        <div class="tab-pane fade" id="project" role="tabpanel" aria-labelledby="project-tab">
            <div class="form-container">
                <div class="form-section-title">
                    <span class="section-icon"><i class="fas fa-project-diagram"></i></span>
                    Client Project Details
                </div>
                <form asp-action="AddProjectBlueprints" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-grid">
                        <div class="form-group form-grid-full">
                            <label asp-for="BlueprintImage" class="control-label">
                                <i class="fas fa-image"></i>
                                Blueprint File
                            </label>
                            <div class="file-upload-wrap">
                                <input asp-for="BlueprintImage" type="file" accept="image/*" required data-upload-target="project" />
                                <div class="file-upload-zone" data-upload-zone="project">
                                    <div class="file-upload-icon">
                                        <i class="fas fa-cloud-upload-alt"></i>
                                    </div>
                                    <p class="file-upload-title">
                                        Drop your blueprint here or <span class="accent">click to browse</span>
                                    </p>
                                    <p class="file-upload-hint">PNG, JPG up to 10MB</p>
                                    <span class="file-name-display">
                                        <i class="fas fa-file-image"></i>
                                        <span data-file-name="project"></span>
                                    </span>
                                </div>
                            </div>
                            <span asp-validation-for="BlueprintImage" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="blueprintName" class="control-label">
                                <i class="fas fa-heading"></i>
                                Project Name
                            </label>
                            <input asp-for="blueprintName" class="form-control" placeholder="e.g. Dela Cruz Residence" />
                            <span asp-validation-for="blueprintName" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label for="clientDropdown" class="control-label">
                                <i class="fas fa-user"></i>
                                Select Client
                            </label>
                            <select asp-for="clentId" class="form-control" id="clientDropdown">
                                <option value="">-- Select Client --</option>
                                @foreach (var client in Model.Clients)
                                {
                                    <option value="@client.Value">@client.Text</option>
                                }
                            </select>
                            <span asp-validation-for="clentId" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="blueprintPrice" class="control-label">
                                <i class="fas fa-peso-sign"></i>
                                Budget (in Pesos)
                            </label>
                            <input asp-for="blueprintPrice" type="text" class="form-control price-input" placeholder="0" inputmode="numeric" autocomplete="off" />
                            <span asp-validation-for="blueprintPrice" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="projectTrack_dueDate" class="control-label">
                                <i class="fas fa-calendar-alt"></i>
                                Project Due Date
                            </label>
                            <input asp-for="projectTrack_dueDate" type="date" class="form-control" />
                            <span asp-validation-for="projectTrack_dueDate" class="text-danger"></span>
                        </div>

                        <div class="form-group form-grid-full">
                            <label asp-for="blueprintDescription" class="control-label">
                                <i class="fas fa-align-left"></i>
                                Project Description
                            </label>
                            <textarea asp-for="blueprintDescription" class="bp-desc form-control" placeholder="Outline the scope, requirements, and goals for this project..."></textarea>
                            <span asp-validation-for="blueprintDescription" class="text-danger"></span>
                        </div>
                    </div>

                    <input type="hidden" asp-for="blueprintIsForSale" value="false" />
                    <input type="hidden" asp-for="blueprintStyle" value="###" />

                    <div class="form-footer">
                        <button type="submit" class="add-bp">
                            <i class="fas fa-paper-plane"></i>
                            Upload for Project
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.querySelector('.sidebar');
            const sidebarToggler = document.querySelector('.sidebar-toggler');
            const mainContent = document.querySelector('main.container');

            function adjustMainContent() {
                if (sidebar && mainContent) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '110px';
                        mainContent.style.maxWidth = 'calc(100% - 130px)';
                        mainContent.style.width = 'calc(100% - 130px)';
                    } else {
                        mainContent.style.marginLeft = '300px';
                        mainContent.style.maxWidth = 'calc(100% - 320px)';
                        mainContent.style.width = 'calc(100% - 320px)';
                    }
                }
            }

            adjustMainContent();

            if (sidebarToggler) {
                sidebarToggler.addEventListener('click', function() {
                    setTimeout(adjustMainContent, 50);
                });
            }

            // File upload preview
            document.querySelectorAll('input[type="file"][data-upload-target]').forEach(input => {
                input.addEventListener('change', function () {
                    const target = this.dataset.uploadTarget;
                    const zone = document.querySelector(`[data-upload-zone="${target}"]`);
                    const nameEl = document.querySelector(`[data-file-name="${target}"]`);

                    if (this.files && this.files[0]) {
                        zone.classList.add('has-file');
                        nameEl.textContent = this.files[0].name;
                    } else {
                        zone.classList.remove('has-file');
                        nameEl.textContent = '';
                    }
                });
            });

            // Price input — format with commas while typing, strip on submit
            document.querySelectorAll('.price-input').forEach(function (inp) {
                var format = function (val) {
                    var digits = String(val).replace(/\D/g, '');
                    return digits ? Number(digits).toLocaleString('en-US') : '';
                };
                inp.value = format(inp.value);
                inp.addEventListener('input', function () {
                    var caret = this.selectionStart;
                    var before = this.value;
                    var formatted = format(before);
                    this.value = formatted;
                    var diff = formatted.length - before.length;
                    try { this.setSelectionRange(caret + diff, caret + diff); } catch (e) {}
                });
                var form = inp.closest('form');
                if (form) {
                    form.addEventListener('submit', function () {
                        inp.value = inp.value.replace(/,/g, '');
                    });
                }
            });
        });
    </script>
}
