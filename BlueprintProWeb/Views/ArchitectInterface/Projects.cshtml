@model IEnumerable<BlueprintProWeb.Models.Project>

@{
    ViewData["Title"] = "My Projects";
    Layout = "~/Views/Shared/_ArchitectSharedLayout.cshtml";
}

@section Styles {
    <style>
        body::before {
            background: url("/images/BPP_Dashboard_BG.png") center/cover no-repeat !important;
            opacity: 0.08 !important;
        }

        body {
            background: linear-gradient(135deg, #e8edf5 0%, #d4dce9 100%) !important;
            overflow-y: auto !important;
            height: auto !important;
            font-family: 'Raleway', sans-serif !important;
        }

        main.container {
            margin-left: 270px;
            margin-top: 90px;
            padding: 1.5rem;
            padding-top: 2rem;
            max-width: calc(100% - 270px);
            transition: margin-left 0.4s ease, max-width 0.4s ease;
        }

        .sidebar.collapsed ~ * main.container,
        body:has(.sidebar.collapsed) main.container {
            margin-left: 85px;
            max-width: calc(100% - 85px);
        }

        /* ── Page Header (unified) ─────────── */
        .page-header {
            margin-bottom: 1.75rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid #f0f4f8;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
        }

        .page-header-left {
            display: flex;
            align-items: center;
            gap: 0.95rem;
        }

        .page-header-icon {
            width: 46px;
            height: 46px;
            border-radius: 13px;
            background: rgba(13, 60, 128, 0.08);
            color: #0D3C80;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
            flex-shrink: 0;
        }

        .page-title {
            font-weight: 600;
            font-size: 1.6rem;
            letter-spacing: -0.3px;
            color: #091635;
            margin: 0;
            line-height: 1.2;
        }

        .page-header-icon .material-symbols-rounded {
            font-size: 1.5rem;
        }

        .page-subtitle {
            font-size: 0.85rem;
            font-weight: 500;
            color: #8b97a8;
            margin-top: 0.2rem;
        }

        .bin-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: #F8FAFC;
            color: #344EAD;
            border: 1.5px solid #E2E8F0;
            border-radius: 10px;
            padding: 0.65rem 1.15rem;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.2s ease;
            cursor: pointer;
        }

        .bin-btn:hover {
            background: #F1F7F9;
            border-color: #344EAD;
            color: #344EAD;
            transform: translateY(-1px);
        }

        .bin-btn i {
            font-size: 0.85rem;
        }

        /* ── Projects Grid ────────────────────────────────────── */
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.25rem;
        }

        .project-card {
            background: #FFFFFF;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(7, 23, 68, 0.07);
            border: 1px solid #eef2f7;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: all 0.25s ease;
        }

        .project-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(52, 78, 173, 0.12);
            border-color: rgba(52, 78, 173, 0.2);
        }

        .project-image-wrap {
            position: relative;
            width: 100%;
            height: 170px;
            overflow: hidden;
            background: #F1F7F9;
        }

        .project-image-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.35s ease;
        }

        .project-card:hover .project-image-wrap img {
            transform: scale(1.03);
        }

        .project-status-pill {
            position: absolute;
            top: 0.85rem;
            left: 0.85rem;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.35rem 0.75rem;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            backdrop-filter: blur(8px);
        }

        .project-status-pill i {
            font-size: 0.55rem;
        }

        .status-ongoing {
            background: rgba(59, 130, 246, 0.92);
            color: #FFFFFF;
        }

        .status-review {
            background: rgba(245, 158, 11, 0.92);
            color: #FFFFFF;
        }

        .status-compliance {
            background: rgba(139, 92, 246, 0.92);
            color: #FFFFFF;
        }

        .status-finalization {
            background: rgba(16, 185, 129, 0.92);
            color: #FFFFFF;
        }

        .status-finished {
            background: rgba(34, 197, 94, 0.92);
            color: #FFFFFF;
        }

        .project-body {
            padding: 1.25rem 1.35rem 1.1rem;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .project-title {
            font-weight: 700;
            font-size: 1.1rem;
            color: #1a202c;
            margin: 0 0 0.85rem;
            letter-spacing: -0.2px;
            line-height: 1.3;
            display: -webkit-box;
            -webkit-line-clamp: 1;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .project-meta {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.65rem;
            margin-bottom: 1rem;
        }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            padding: 0.6rem 0.75rem;
            background: #F8FAFC;
            border-radius: 8px;
            border-left: 3px solid #344EAD;
        }

        .meta-icon {
            width: 28px;
            height: 28px;
            background: linear-gradient(135deg, #344EAD 0%, #2563EB 100%);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #FFFFFF;
            font-size: 0.75rem;
            flex-shrink: 0;
        }

        .meta-content {
            display: flex;
            flex-direction: column;
            gap: 0.1rem;
            min-width: 0;
        }

        .meta-label {
            font-size: 0.65rem;
            font-weight: 700;
            color: #64748B;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .meta-value {
            font-size: 0.82rem;
            font-weight: 600;
            color: #1a202c;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .meta-value.client-link {
            color: #344EAD;
            cursor: pointer;
            border-bottom: 1px dashed transparent;
            transition: all 0.2s ease;
        }

        .meta-value.client-link:hover {
            color: #2563EB;
            border-bottom-color: #2563EB;
        }

        .project-actions {
            display: flex;
            gap: 0.6rem;
            margin-top: auto;
            padding-top: 1rem;
            border-top: 1px solid #f0f4f8;
        }

        .track-btn {
            flex: 1;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            background: linear-gradient(135deg, #344EAD 0%, #2563EB 100%);
            color: #FFFFFF;
            border: none;
            border-radius: 8px;
            padding: 0.7rem 1.1rem;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-decoration: none;
            transition: all 0.2s ease;
            box-shadow: 0 2px 4px rgba(52, 78, 173, 0.2);
        }

        .track-btn:hover {
            background: linear-gradient(135deg, #2563EB 0%, #1d4ed8 100%);
            transform: translateY(-1px);
            box-shadow: 0 4px 10px rgba(52, 78, 173, 0.3);
            color: #FFFFFF;
            text-decoration: none;
        }

        .delete-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            background: #FEF2F2;
            color: #DC2626;
            border: 1.5px solid #FECACA;
            border-radius: 8px;
            font-size: 0.85rem;
            transition: all 0.2s ease;
            cursor: pointer;
        }

        .delete-btn:hover {
            background: #DC2626;
            color: #FFFFFF;
            border-color: #DC2626;
            transform: translateY(-1px);
        }

        /* ── Empty State ──────────────────────────────────────── */
        .empty-state {
            background: #FFFFFF;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(7, 23, 68, 0.07);
            border: 1px solid #eef2f7;
            text-align: center;
            padding: 4rem 2rem;
        }

        .empty-state-icon {
            width: 72px;
            height: 72px;
            background: rgba(52, 78, 173, 0.08);
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #344EAD;
            font-size: 1.75rem;
            margin-bottom: 1.25rem;
        }

        .empty-state-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: #1a202c;
            margin-bottom: 0.35rem;
            letter-spacing: -0.2px;
        }

        .empty-state-subtitle {
            font-size: 0.875rem;
            color: #64748B;
            line-height: 1.55;
            max-width: 380px;
            margin: 0 auto;
        }

        /* ── Modals ───────────────────────────────────────────── */
        .modal-content {
            border-radius: 16px;
            border: 1px solid #eef2f7;
            box-shadow: 0 20px 60px rgba(7, 23, 68, 0.2);
            overflow: hidden;
        }

        .modal-header {
            background: linear-gradient(135deg, #071744 0%, #344EAD 100%);
            color: #FFFFFF;
            border-bottom: none;
            padding: 1.25rem 1.5rem;
        }

        .modal-title {
            font-weight: 700;
            font-size: 1rem;
            display: flex;
            align-items: center;
            gap: 0.55rem;
            letter-spacing: -0.1px;
        }

        .modal-title i {
            font-size: 0.95rem;
        }

        .btn-close {
            filter: invert(1);
            opacity: 0.85;
        }

        .modal-body {
            padding: 1.75rem;
        }

        .modal-footer {
            border-top: 1px solid #f0f4f8;
            padding: 1rem 1.5rem;
        }

        /* ── Profile Card in Modal ────────────────────────────── */
        .profile-main-card {
            background: #F8FAFC;
            border-radius: 12px;
            border: 1px solid #eef2f7;
            padding: 1.25rem;
        }

        .profile-info {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .avatar img {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #FFFFFF;
            box-shadow: 0 4px 12px rgba(52, 78, 173, 0.15);
        }

        .client-name {
            color: #1a202c;
            font-weight: 700;
            font-size: 1.15rem;
            margin: 0 0 0.25rem;
            letter-spacing: -0.2px;
        }

        .profile-info .text-muted {
            color: #64748B !important;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            gap: 0.45rem;
            margin-top: 0.2rem;
        }

        .profile-info .text-muted i {
            width: 14px;
            color: #344EAD;
            font-size: 0.75rem;
        }

        /* ── Deleted Projects List (Bin modal) ────────────────── */
        .deleted-project-item {
            background: #F8FAFC;
            border: 1px solid #eef2f7;
            border-radius: 12px;
            padding: 1rem 1.15rem;
            margin-bottom: 0.85rem;
            text-align: left;
            transition: all 0.2s ease;
        }

        .deleted-project-item:last-child {
            margin-bottom: 0;
        }

        .deleted-project-item:hover {
            border-color: rgba(52, 78, 173, 0.2);
            box-shadow: 0 2px 8px rgba(52, 78, 173, 0.06);
        }

        .deleted-project-title {
            font-weight: 700;
            font-size: 0.95rem;
            color: #1a202c;
            margin-bottom: 0.5rem;
            letter-spacing: -0.1px;
        }

        .deleted-project-meta {
            font-size: 0.8rem;
            color: #64748B;
            margin-bottom: 0.15rem;
            display: flex;
            align-items: center;
            gap: 0.45rem;
        }

        .deleted-project-meta i {
            width: 13px;
            color: #344EAD;
            font-size: 0.72rem;
        }

        .deleted-project-meta strong {
            color: #1a202c;
            font-weight: 600;
        }

        .deleted-actions {
            display: flex;
            gap: 0.5rem;
            margin-top: 0.85rem;
            padding-top: 0.85rem;
            border-top: 1px solid #eef2f7;
        }

        .btn-restore {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: linear-gradient(135deg, #10B981 0%, #059669 100%);
            color: #FFFFFF;
            border: none;
            border-radius: 8px;
            padding: 0.5rem 0.9rem;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            transition: all 0.2s ease;
            box-shadow: 0 2px 4px rgba(16, 185, 129, 0.2);
        }

        .btn-restore:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 10px rgba(16, 185, 129, 0.3);
            color: #FFFFFF;
        }

        .btn-delete-permanent {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: #FEF2F2;
            color: #DC2626;
            border: 1.5px solid #FECACA;
            border-radius: 8px;
            padding: 0.5rem 0.9rem;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            transition: all 0.2s ease;
            cursor: pointer;
        }

        .btn-delete-permanent:hover {
            background: #DC2626;
            color: #FFFFFF;
            border-color: #DC2626;
        }

        .confirm-icon {
            width: 64px;
            height: 64px;
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }

        .confirm-icon.warning {
            background: rgba(245, 158, 11, 0.1);
            color: #F59E0B;
        }

        .confirm-icon.danger {
            background: rgba(220, 38, 38, 0.1);
            color: #DC2626;
        }

        .confirm-title {
            font-weight: 700;
            font-size: 1.05rem;
            color: #1a202c;
            margin-bottom: 0.4rem;
        }

        .confirm-subtitle {
            font-size: 0.85rem;
            color: #64748B;
            line-height: 1.5;
        }

        .btn-modal-cancel {
            background: #F8FAFC;
            color: #64748B;
            border: 1.5px solid #E2E8F0;
            border-radius: 8px;
            padding: 0.6rem 1.25rem;
            font-size: 0.8rem;
            font-weight: 600;
            transition: all 0.2s ease;
        }

        .btn-modal-cancel:hover {
            background: #F1F7F9;
            color: #1a202c;
        }

        .btn-modal-confirm {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: linear-gradient(135deg, #DC2626 0%, #B91C1C 100%);
            color: #FFFFFF;
            border: none;
            border-radius: 8px;
            padding: 0.6rem 1.25rem;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            transition: all 0.2s ease;
            box-shadow: 0 2px 4px rgba(220, 38, 38, 0.2);
        }

        .btn-modal-confirm:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 10px rgba(220, 38, 38, 0.3);
            color: #FFFFFF;
        }

        /* ── Responsive ───────────────────────────────────────── */
        @@media (max-width: 1200px) {
            .projects-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 768px) {
            main.container {
                margin-left: 0 !important;
                margin-top: 100px;
                max-width: 100% !important;
                padding: 1rem;
                padding-top: 2rem;
            }

            .page-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }

            .page-title {
                font-size: 1.4rem;
            }

            .project-meta {
                grid-template-columns: 1fr;
            }

            .modal-body {
                padding: 1.25rem;
            }
        }
    </style>
}

<div>
    <div class="page-header">
        <div class="page-header-left">
            <div class="page-header-icon">
                <span class="material-symbols-rounded">note_stack</span>
            </div>
            <div>
                <h1 class="page-title">My Projects</h1>
                <div class="page-subtitle">Oversee your active client projects</div>
            </div>
        </div>
        <button type="button" class="bin-btn" data-bs-toggle="modal" data-bs-target="#deletedProjectsModal">
            <i class="fas fa-trash-alt"></i>
            Recycle Bin
        </button>
    </div>

    @if (Model.Any())
    {
        <div class="projects-grid">
            @foreach (var item in Model)
            {
                var statusClass = item.project_Status switch
                {
                    "Ongoing" => "status-ongoing",
                    "Review" => "status-review",
                    "Compliance" => "status-compliance",
                    "Finalization" => "status-finalization",
                    "Finished" => "status-finished",
                    _ => "status-ongoing"
                };

                <div class="project-card">
                    <div class="project-image-wrap">
                        <img src="@(item.Blueprint.blueprintImage.StartsWith("/uploads")
                                    ? item.Blueprint.blueprintImage
                                    : Url.Content("~/images/" + item.Blueprint.blueprintImage))"
                             asp-append-version="true"
                             alt="@item.project_Title" />
                        <span class="project-status-pill @statusClass">
                            <i class="fas fa-circle"></i>
                            @item.project_Status
                        </span>
                    </div>

                    <div class="project-body">
                        <h3 class="project-title">@item.project_Title</h3>

                        <div class="project-meta">
                            <div class="meta-item">
                                <div class="meta-icon">
                                    <i class="fas fa-peso-sign"></i>
                                </div>
                                <div class="meta-content">
                                    <span class="meta-label">Budget</span>
                                    <span class="meta-value">₱@item.project_Budget</span>
                                </div>
                            </div>
                            <div class="meta-item">
                                <div class="meta-icon">
                                    <i class="fas fa-user"></i>
                                </div>
                                <div class="meta-content">
                                    <span class="meta-label">Client</span>
                                    <a href="#"
                                       class="meta-value client-link"
                                       data-client-id="@item.Client.Id">
                                        @item.Client.user_fname @item.Client.user_lname
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="project-actions">
                            <a asp-controller="ArchitectInterface"
                               asp-action="ProjectTracker"
                               asp-route-id="@item.blueprint_Id"
                               class="track-btn">
                                <i class="fas fa-eye"></i>
                                Track Project
                            </a>
                            @if (item.project_Status == "Ongoing")
                            {
                                <button type="button"
                                        class="delete-btn"
                                        title="Move to Bin"
                                        onclick="openMoveToBinModal('@item.project_Id')">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="fas fa-project-diagram"></i>
            </div>
            <div class="empty-state-title">No Projects Yet</div>
            <div class="empty-state-subtitle">
                Your active projects will appear here once clients start working with you.
            </div>
        </div>
    }
</div>

<!-- Client Profile Modal -->
<div class="modal fade" id="clientProfileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-user-circle"></i>
                    Client Profile
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="profile-main-card">
                    <div class="profile-info">
                        <div class="avatar">
                            <img id="clientProfilePhoto" src="~/images/profile.jpg" alt="Avatar">
                        </div>
                        <div class="user-details">
                            <h3 id="clientProfileName" class="client-name"></h3>
                            <div id="clientProfileEmail" class="text-muted">
                                <i class="fas fa-envelope"></i>
                                <span></span>
                            </div>
                            <div id="clientProfilePhone" class="text-muted">
                                <i class="fas fa-phone"></i>
                                <span></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Deleted Projects (Bin) Modal -->
<div class="modal fade" id="deletedProjectsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-trash-alt"></i>
                    Recycle Bin
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="deletedProjectsContainer" class="text-center text-muted">
                    <i class="fas fa-spinner fa-spin"></i> Loading deleted projects...
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Move to Bin Confirmation Modal -->
<div class="modal fade" id="moveToBinModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-trash-alt"></i>
                    Move to Bin
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <div class="confirm-icon warning">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <div class="confirm-title">Move this project to the bin?</div>
                <div class="confirm-subtitle">You can restore it later from the Recycle Bin if needed.</div>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                <form id="moveToBinForm" method="post" action="/ArchitectInterface/DeleteProject">
                    <input type="hidden" name="id" id="moveToBinProjectId" />
                    <button type="submit" class="btn-modal-confirm">
                        <i class="fas fa-trash-alt"></i> Move to Bin
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Permanent Delete Confirmation Modal -->
<div class="modal fade" id="permanentDeleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #B91C1C 0%, #DC2626 100%);">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle"></i>
                    Permanently Delete
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <div class="confirm-icon danger">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <div class="confirm-title">Permanently delete this project?</div>
                <div class="confirm-subtitle">Once deleted, this project cannot be restored.</div>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                <form id="permanentDeleteForm" method="post" action="/ArchitectInterface/PermanentlyDeleteProject">
                    <input type="hidden" name="id" id="permanentDeleteProjectId" />
                    <button type="submit" class="btn-modal-confirm">
                        <i class="fas fa-trash-alt"></i> Delete Forever
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const sidebar = document.querySelector('.sidebar');
            const sidebarToggler = document.querySelector('.sidebar-toggler');
            const mainContent = document.querySelector('main.container');

            function adjustMainContent() {
                if (sidebar && mainContent) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '85px';
                        mainContent.style.maxWidth = 'calc(100% - 85px)';
                    } else {
                        mainContent.style.marginLeft = '270px';
                        mainContent.style.maxWidth = 'calc(100% - 270px)';
                    }
                }
            }

            adjustMainContent();

            if (sidebarToggler) {
                sidebarToggler.addEventListener('click', function () {
                    setTimeout(adjustMainContent, 50);
                });
            }

            // Client profile modal
            const clientProfileModal = new bootstrap.Modal(document.getElementById('clientProfileModal'));

            document.querySelectorAll('.client-link').forEach(link => {
                link.addEventListener('click', function (e) {
                    e.preventDefault();

                    const clientId = this.dataset.clientId;

                    fetch(`/ArchitectInterface/GetClientProfile?clientId=${clientId}`)
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                document.getElementById("clientProfileName").innerText = data.name;
                                document.getElementById("clientProfileEmail").querySelector('span').innerText = data.email || "No email provided";
                                document.getElementById("clientProfilePhone").querySelector('span').innerText = data.phone || "No phone provided";
                                const profilePhoto = data.profilePhoto || "/images/profile.jpg";
                                document.getElementById("clientProfilePhoto").src = profilePhoto;

                                clientProfileModal.show();
                            } else {
                                alert(data.message);
                            }
                        })
                        .catch(() => alert("Failed to load client profile."));
                });
            });
        });

        function openMoveToBinModal(projectId) {
            document.getElementById('moveToBinProjectId').value = projectId;
            new bootstrap.Modal(document.getElementById('moveToBinModal')).show();
        }

        function openPermanentDeleteModal(projectId) {
            const binModalEl = document.getElementById('deletedProjectsModal');
            const binModalInstance = bootstrap.Modal.getInstance(binModalEl);
            if (binModalInstance) {
                binModalInstance.hide();
            }

            setTimeout(() => {
                document.getElementById('permanentDeleteProjectId').value = projectId;
                new bootstrap.Modal(document.getElementById('permanentDeleteModal')).show();
            }, 400);
        }

        document.addEventListener('DOMContentLoaded', function () {
            const deletedProjectsModal = document.getElementById('deletedProjectsModal');
            const container = document.getElementById('deletedProjectsContainer');

            deletedProjectsModal.addEventListener('show.bs.modal', function () {
                container.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Loading deleted projects...';

                fetch('/ArchitectInterface/DeletedProjects')
                    .then(res => res.json())
                    .then(data => {
                        if (data.length === 0) {
                            container.innerHTML = `
                                <div class="empty-state" style="padding: 2.5rem 1rem; box-shadow: none; border: none;">
                                    <div class="empty-state-icon">
                                        <i class="fas fa-trash-alt"></i>
                                    </div>
                                    <div class="empty-state-title">Bin is Empty</div>
                                    <div class="empty-state-subtitle">No deleted projects found.</div>
                                </div>`;
                            return;
                        }

                        container.innerHTML = data.map(p => `
                            <div class="deleted-project-item">
                                <div class="deleted-project-title">${p.project_Title}</div>
                                <div class="deleted-project-meta">
                                    <i class="fas fa-user"></i>
                                    <strong>Client:</strong> ${p.clientName}
                                </div>
                                <div class="deleted-project-meta">
                                    <i class="fas fa-calendar-alt"></i>
                                    <strong>Deleted On:</strong> ${new Date(p.deletedDate).toLocaleDateString()}
                                </div>
                                <div class="deleted-actions">
                                    <form method="post" action="/ArchitectInterface/RestoreProject">
                                        <input type="hidden" name="id" value="${p.project_Id}">
                                        <button type="submit" class="btn-restore">
                                            <i class="fas fa-undo"></i> Restore
                                        </button>
                                    </form>
                                    <button type="button" class="btn-delete-permanent"
                                            onclick="openPermanentDeleteModal('${p.project_Id}')">
                                        <i class="fas fa-trash-alt"></i> Delete
                                    </button>
                                </div>
                            </div>
                        `).join('');
                    })
                    .catch(() => {
                        container.innerHTML = '<p class="text-danger mt-3">Failed to load deleted projects.</p>';
                    });
            });
        });
    </script>
}
