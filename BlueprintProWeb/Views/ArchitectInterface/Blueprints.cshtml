@model IEnumerable<BlueprintProWeb.Models.Blueprint>

@{
    ViewData["Title"] = "My Blueprints";
    Layout = "~/Views/Shared/_ArchitectSharedLayout.cshtml";
}

@section Styles {
    <style>
        body::before {
            background: url("/images/BPP_Dashboard_BG.png") center/cover no-repeat !important;
            opacity: 0.1 !important;
        }

        body {
            background: #F1F7F9 !important;
            overflow-y: auto !important;
            height: auto !important;
            font-family: 'Raleway', sans-serif !important;
        }

        main.container {
            margin-left: 300px;
            margin-top: 120px;
            padding: 1.5rem;
            padding-top: 4rem;
            max-width: calc(100% - 320px);
            transition: margin-left 0.4s ease, max-width 0.4s ease;
        }

        .sidebar.collapsed ~ * main.container,
        body:has(.sidebar.collapsed) main.container {
            margin-left: 110px;
            max-width: calc(100% - 130px);
        }

        /* ── Page Header (matches dashboard-greeting) ─────────── */
        .page-header {
            color: #1a202c;
            margin-bottom: 1.5rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid #e8edf5;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
        }

        .page-title {
            font-weight: 700;
            font-size: 1.75rem;
            letter-spacing: -0.3px;
            color: #1a202c;
            margin: 0;
        }

        .page-subtitle {
            font-size: 0.9rem;
            font-weight: 400;
            color: #94a3b8;
            margin-top: 0.3rem;
        }

        .add-blueprint-button {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: linear-gradient(135deg, #344EAD 0%, #2563EB 100%);
            color: #FFFFFF;
            border: none;
            border-radius: 10px;
            padding: 0.7rem 1.25rem;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-decoration: none;
            transition: all 0.2s ease;
            box-shadow: 0 2px 8px rgba(52, 78, 173, 0.25);
        }

        .add-blueprint-button:hover {
            background: linear-gradient(135deg, #2563EB 0%, #1d4ed8 100%);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(52, 78, 173, 0.35);
            color: #FFFFFF;
            text-decoration: none;
        }

        .add-blueprint-button i {
            font-size: 0.85rem;
        }

        /* ── Toolbar (stats + count) ──────────────────────────── */
        .blueprints-toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.25rem;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .blueprint-count {
            display: inline-flex;
            align-items: center;
            gap: 0.55rem;
            color: #64748B;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .blueprint-count strong {
            color: #344EAD;
            font-weight: 700;
            font-size: 0.95rem;
        }

        .blueprint-count .count-icon {
            width: 28px;
            height: 28px;
            background: rgba(52, 78, 173, 0.08);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #344EAD;
            font-size: 0.85rem;
        }

        /* ── Blueprints Grid ──────────────────────────────────── */
        .blueprints-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
            gap: 1.35rem;
        }

        /* ── Product Card ─────────────────────────────────────── */
        .blueprint-card {
            background: #FFFFFF;
            border-radius: 14px;
            border: 1px solid #eef2f7;
            box-shadow: 0 2px 12px rgba(7, 23, 68, 0.07);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: all 0.3s ease;
            position: relative;
        }

        .blueprint-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 28px rgba(52, 78, 173, 0.14);
            border-color: rgba(52, 78, 173, 0.22);
        }

        /* ── Card Image Area ──────────────────────────────────── */
        .card-media {
            position: relative;
            width: 100%;
            height: 200px;
            overflow: hidden;
            background: linear-gradient(135deg, #EEF2F7 0%, #F1F7F9 100%);
        }

        .card-media img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.45s ease;
        }

        .blueprint-card:hover .card-media img {
            transform: scale(1.06);
        }

        /* Subtle gradient overlay for visual polish */
        .card-media::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(7, 23, 68, 0) 55%, rgba(7, 23, 68, 0.25) 100%);
            pointer-events: none;
        }

        .media-badge {
            position: absolute;
            top: 0.85rem;
            z-index: 2;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.38rem 0.75rem;
            border-radius: 20px;
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            backdrop-filter: blur(8px);
        }

        .badge-style {
            left: 0.85rem;
            background: rgba(255, 255, 255, 0.92);
            color: #344EAD;
            border: 1px solid rgba(52, 78, 173, 0.15);
        }

        .badge-style i {
            font-size: 0.6rem;
        }

        .badge-sale {
            right: 0.85rem;
            background: rgba(16, 185, 129, 0.92);
            color: #FFFFFF;
        }

        .badge-draft {
            right: 0.85rem;
            background: rgba(100, 116, 139, 0.92);
            color: #FFFFFF;
        }

        .badge-sale i,
        .badge-draft i {
            font-size: 0.5rem;
        }

        /* ── Card Body ────────────────────────────────────────── */
        .card-body {
            padding: 1.1rem 1.25rem 1.25rem;
            display: flex;
            flex-direction: column;
            flex: 1;
            background: #FFFFFF;
        }

        .blueprint-title {
            font-size: 1.05rem;
            font-weight: 700;
            color: #1a202c;
            margin: 0 0 0.5rem;
            letter-spacing: -0.2px;
            line-height: 1.35;
            display: -webkit-box;
            -webkit-line-clamp: 1;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .blueprint-style-tag {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            color: #64748B;
            font-size: 0.78rem;
            font-weight: 600;
            margin-bottom: 0.9rem;
        }

        .blueprint-style-tag i {
            color: #344EAD;
            font-size: 0.72rem;
        }

        /* Price row */
        .price-row {
            display: flex;
            align-items: baseline;
            gap: 0.4rem;
            padding: 0.85rem 0.95rem;
            background: linear-gradient(135deg, rgba(52, 78, 173, 0.06) 0%, rgba(37, 99, 235, 0.06) 100%);
            border: 1px solid rgba(52, 78, 173, 0.12);
            border-radius: 10px;
            margin-bottom: 1rem;
        }

        .price-label {
            font-size: 0.65rem;
            font-weight: 700;
            color: #64748B;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            margin-right: auto;
        }

        .price-currency {
            font-size: 0.95rem;
            font-weight: 700;
            color: #344EAD;
        }

        .price-value {
            font-size: 1.35rem;
            font-weight: 800;
            color: #344EAD;
            letter-spacing: -0.4px;
            line-height: 1;
        }

        /* Action row (Edit button) */
        .card-action {
            margin-top: auto;
        }

        .edit-blueprint-btn {
            width: 100%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            background: linear-gradient(135deg, #344EAD 0%, #2563EB 100%);
            color: #FFFFFF;
            border: none;
            border-radius: 10px;
            padding: 0.75rem 1.1rem;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 2px 6px rgba(52, 78, 173, 0.2);
        }

        .edit-blueprint-btn:hover {
            background: linear-gradient(135deg, #2563EB 0%, #1d4ed8 100%);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(52, 78, 173, 0.3);
            color: #FFFFFF;
        }

        /* ── Empty State ──────────────────────────────────────── */
        .empty-state {
            background: #FFFFFF;
            border-radius: 14px;
            box-shadow: 0 2px 12px rgba(7, 23, 68, 0.07);
            border: 1px solid #eef2f7;
            text-align: center;
            padding: 4rem 2rem;
        }

        .empty-state-icon {
            width: 72px;
            height: 72px;
            background: rgba(52, 78, 173, 0.08);
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #344EAD;
            font-size: 1.75rem;
            margin-bottom: 1.25rem;
        }

        .empty-state-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: #1a202c;
            margin-bottom: 0.35rem;
            letter-spacing: -0.2px;
        }

        .empty-state-subtitle {
            font-size: 0.875rem;
            color: #64748B;
            line-height: 1.55;
            max-width: 380px;
            margin: 0 auto 1.5rem;
        }

        /* ── Modal Styling ────────────────────────────────────── */
        .modal-content {
            border-radius: 16px;
            border: 1px solid #eef2f7;
            box-shadow: 0 20px 60px rgba(7, 23, 68, 0.2);
            overflow: hidden;
        }

        .modal-header {
            background: linear-gradient(135deg, #071744 0%, #344EAD 100%);
            color: #FFFFFF;
            border-bottom: none;
            padding: 1.25rem 1.5rem;
        }

        .modal-title {
            font-weight: 700;
            font-size: 1rem;
            display: flex;
            align-items: center;
            gap: 0.55rem;
            letter-spacing: -0.1px;
            color: #FFFFFF;
        }

        .btn-close {
            filter: invert(1);
            opacity: 0.85;
        }

        .modal-body {
            padding: 1.75rem;
        }

        .modal-footer {
            border-top: 1px solid #f0f4f8;
            padding: 1rem 1.5rem;
        }

        .form-label {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            font-size: 0.72rem;
            font-weight: 700;
            color: #64748B;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
        }

        .form-label i {
            color: #344EAD;
            font-size: 0.72rem;
        }

        .form-control,
        .form-select {
            border: 1.5px solid #E2E8F0;
            border-radius: 10px;
            padding: 0.7rem 0.95rem;
            font-size: 0.88rem;
            color: #1a202c;
            background: #F8FAFC;
            transition: all 0.2s ease;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: #344EAD;
            background: #FFFFFF;
            box-shadow: 0 0 0 3px rgba(52, 78, 173, 0.12);
        }

        .form-text-hint {
            display: block;
            font-size: 0.72rem;
            color: #94a3b8;
            margin-top: 0.35rem;
        }

        .save-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: linear-gradient(135deg, #344EAD 0%, #2563EB 100%);
            color: #FFFFFF;
            border: none;
            border-radius: 10px;
            padding: 0.65rem 1.25rem;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.2s ease;
            box-shadow: 0 2px 6px rgba(52, 78, 173, 0.2);
        }

        .save-btn:hover {
            background: linear-gradient(135deg, #2563EB 0%, #1d4ed8 100%);
            transform: translateY(-1px);
            box-shadow: 0 4px 10px rgba(52, 78, 173, 0.3);
            color: #FFFFFF;
        }

        .btn-delete-modal {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: #FEF2F2;
            color: #DC2626;
            border: 1.5px solid #FECACA;
            border-radius: 10px;
            padding: 0.6rem 1.15rem;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.2s ease;
            cursor: pointer;
        }

        .btn-delete-modal:hover {
            background: #DC2626;
            color: #FFFFFF;
            border-color: #DC2626;
        }

        .btn-cancel-modal {
            background: #F8FAFC;
            color: #64748B;
            border: 1.5px solid #E2E8F0;
            border-radius: 10px;
            padding: 0.6rem 1.15rem;
            font-size: 0.8rem;
            font-weight: 600;
            transition: all 0.2s ease;
        }

        .btn-cancel-modal:hover {
            background: #F1F7F9;
            color: #1a202c;
        }

        .confirm-icon {
            width: 64px;
            height: 64px;
            background: rgba(220, 38, 38, 0.1);
            color: #DC2626;
            border-radius: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }

        .confirm-title {
            font-weight: 700;
            font-size: 1.05rem;
            color: #1a202c;
            margin-bottom: 0.4rem;
        }

        .confirm-subtitle {
            font-size: 0.85rem;
            color: #64748B;
            line-height: 1.5;
        }

        /* ── Responsive ───────────────────────────────────────── */
        @@media (max-width: 768px) {
            main.container {
                margin-left: 0 !important;
                margin-top: 100px;
                max-width: 100% !important;
                padding: 1rem;
                padding-top: 2rem;
            }

            .page-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }

            .page-title {
                font-size: 1.4rem;
            }

            .blueprints-grid {
                grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
                gap: 1rem;
            }

            .modal-body {
                padding: 1.25rem;
            }
        }

        @@media (max-width: 576px) {
            .blueprints-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div>
    <div class="page-header">
        <div>
            <h1 class="page-title">My Blueprints</h1>
            <div class="page-subtitle">Manage your uploaded blueprint portfolio</div>
        </div>
        @if (Model.Any())
        {
            <a class="add-blueprint-button" asp-controller="ArchitectInterface" asp-action="AddBlueprints">
                <i class="fas fa-plus"></i>
                Add Blueprint
            </a>
        }
    </div>

    @if (Model.Any())
    {
        <div class="blueprints-toolbar">
            <div class="blueprint-count">
                <span class="count-icon"><i class="fas fa-layer-group"></i></span>
                <span><strong>@Model.Count()</strong> @(Model.Count() == 1 ? "blueprint" : "blueprints") in your portfolio</span>
            </div>
        </div>

        <div class="blueprints-grid">
            @foreach (var item in Model)
            {
                <div class="blueprint-card">
                    <div class="card-media">
                        <img src="~/images/@item.blueprintImage"
                             asp-append-version="true"
                             alt="@item.blueprintName" />

                        @if (!string.IsNullOrEmpty(item.blueprintStyle))
                        {
                            <span class="media-badge badge-style">
                                <i class="fas fa-palette"></i>
                                @item.blueprintStyle
                            </span>
                        }

                        @if (item.blueprintIsForSale)
                        {
                            <span class="media-badge badge-sale">
                                <i class="fas fa-circle"></i>
                                For Sale
                            </span>
                        }
                        else
                        {
                            <span class="media-badge badge-draft">
                                <i class="fas fa-circle"></i>
                                Draft
                            </span>
                        }
                    </div>

                    <div class="card-body">
                        <h3 class="blueprint-title">@item.blueprintName</h3>
                        <div class="blueprint-style-tag">
                            <i class="fas fa-drafting-compass"></i>
                            @(string.IsNullOrEmpty(item.blueprintStyle) ? "Uncategorized" : item.blueprintStyle)
                        </div>

                        <div class="price-row">
                            <span class="price-label">Price</span>
                            <span class="price-currency">₱</span>
                            <span class="price-value">@item.blueprintPrice.ToString("N0")</span>
                        </div>

                        <div class="card-action">
                            <button type="button"
                                    class="edit-blueprint-btn"
                                    data-id="@item.blueprintId"
                                    data-name="@item.blueprintName"
                                    data-price="@item.blueprintPrice"
                                    data-style="@item.blueprintStyle"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editBlueprintModal">
                                <i class="fas fa-pen-to-square"></i>
                                Edit Blueprint
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="fas fa-drafting-compass"></i>
            </div>
            <div class="empty-state-title">No Blueprints Yet</div>
            <div class="empty-state-subtitle">
                Start building your portfolio by uploading your first blueprint. Clients will be able to browse and purchase it from the marketplace.
            </div>
            <a class="add-blueprint-button" asp-controller="ArchitectInterface" asp-action="AddBlueprints">
                <i class="fas fa-plus"></i>
                Add Your First Blueprint
            </a>
        </div>
    }
</div>

<!-- EDIT BLUEPRINT MODAL -->
<div class="modal fade" id="editBlueprintModal" tabindex="-1" aria-labelledby="editBlueprintLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="EditBlueprint" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="editBlueprintLabel">
                        <i class="fas fa-pen-to-square"></i>
                        Edit Blueprint
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" name="blueprintId" id="edit-id" />

                    <div class="mb-3">
                        <label class="form-label">
                            <i class="fas fa-heading"></i>
                            Blueprint Name
                        </label>
                        <input type="text" class="form-control" name="blueprintName" id="edit-name" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            <i class="fas fa-peso-sign"></i>
                            Price (₱)
                        </label>
                        <input type="number" class="form-control" name="blueprintPrice" id="edit-price" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            <i class="fas fa-palette"></i>
                            Style
                        </label>
                        <select class="form-select" name="blueprintStyle" id="edit-style">
                            <option value="Modern">Modern</option>
                            <option value="Traditional">Traditional</option>
                            <option value="Contemporary">Contemporary</option>
                            <option value="Minimalist">Minimalist</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            <i class="fas fa-image"></i>
                            Change Image
                        </label>
                        <input type="file" class="form-control" name="BlueprintImage" id="edit-file" />
                        <span class="form-text-hint">Leave empty to keep the current image.</span>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn-delete-modal me-auto" id="delete-btn">
                        <i class="fas fa-trash-alt"></i>
                        Delete
                    </button>
                    <button type="button" class="btn-cancel-modal" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="save-btn">
                        <i class="fas fa-save"></i>
                        Save Changes
                    </button>
                </div>
            </form>

            <form id="delete-form" method="post" asp-action="DeleteBlueprint" style="display:none;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="blueprintId" id="delete-id" />
            </form>
        </div>
    </div>
</div>

<!-- DELETE CONFIRMATION MODAL -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #B91C1C 0%, #DC2626 100%);">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle"></i>
                    Delete Blueprint
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <div class="confirm-icon">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <div class="confirm-title">Delete this blueprint?</div>
                <div class="confirm-subtitle">This action cannot be undone. The blueprint will be permanently removed from your portfolio.</div>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn-cancel-modal" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post" asp-action="DeleteBlueprint" asp-controller="ArchitectInterface" style="display: inline;">
                    <input type="hidden" name="blueprintId" id="deleteBlueprintId" />
                    <button type="submit" class="btn-delete-modal" style="background: linear-gradient(135deg, #DC2626 0%, #B91C1C 100%); color: #FFFFFF; border: none;">
                        <i class="fas fa-trash-alt"></i>
                        Delete Forever
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.querySelector('.sidebar');
            const sidebarToggler = document.querySelector('.sidebar-toggler');
            const mainContent = document.querySelector('main.container');

            function adjustMainContent() {
                if (sidebar && mainContent) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '110px';
                        mainContent.style.maxWidth = 'calc(100% - 130px)';
                    } else {
                        mainContent.style.marginLeft = '300px';
                        mainContent.style.maxWidth = 'calc(100% - 320px)';
                    }
                }
            }

            adjustMainContent();

            if (sidebarToggler) {
                sidebarToggler.addEventListener('click', function() {
                    setTimeout(adjustMainContent, 50);
                });
            }
        });

        const editModalEl = document.getElementById('editBlueprintModal');
        const deleteModalEl = document.getElementById('deleteConfirmModal');

        const editModal = new bootstrap.Modal(editModalEl);
        const deleteModal = new bootstrap.Modal(deleteModalEl);

        document.querySelectorAll('.edit-blueprint-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.getElementById('edit-id').value = btn.dataset.id;
                document.getElementById('edit-name').value = btn.dataset.name;
                document.getElementById('edit-price').value = btn.dataset.price;
                document.getElementById('edit-style').value = btn.dataset.style;

                document.getElementById('delete-id').value = btn.dataset.id;
                document.getElementById('deleteBlueprintId').value = btn.dataset.id;

                const fileInput = document.getElementById('edit-file');
                if (fileInput) fileInput.value = '';
            });
        });

        document.getElementById('delete-btn')?.addEventListener('click', function () {
            editModal.hide();
            deleteModal.show();
        });
    </script>
}
