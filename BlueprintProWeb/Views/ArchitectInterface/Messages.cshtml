@model BlueprintProWeb.ViewModels.ChatPageViewModel

@{
    ViewData["Title"] = "Messages";
    Layout = "~/Views/Shared/_ArchitectSharedLayout.cshtml";
}

@section Styles {
    <style>
        body::before {
            background: url("/images/BPP_Dashboard_BG.png") center/cover no-repeat !important;
            opacity: 0.08 !important;
        }

        body {
            background: linear-gradient(135deg, #e8edf5 0%, #d4dce9 100%) !important;
            overflow-y: auto !important;
            height: auto !important;
            font-family: 'Raleway', sans-serif !important;
        }

        main.container {
            margin-left: 270px;
            margin-top: 70px;
            padding: 1.5rem 2rem 3rem;
            padding-top: 2rem;
            max-width: calc(100% - 270px);
            transition: margin-left 0.4s ease, max-width 0.4s ease;
        }

        .sidebar.collapsed ~ * main.container,
        body:has(.sidebar.collapsed) main.container {
            margin-left: 85px;
            max-width: calc(100% - 85px);
        }

        /* ── PAGE HEADER (unified) ── */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.75rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid #f0f4f8;
        }

        .page-header-left {
            display: flex;
            align-items: center;
            gap: 0.95rem;
        }

        .page-header-icon {
            width: 46px;
            height: 46px;
            border-radius: 13px;
            background: rgba(13, 60, 128, 0.08);
            color: #0D3C80;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.15rem;
            flex-shrink: 0;
        }

        .page-title {
            font-weight: 600;
            font-size: 1.6rem;
            letter-spacing: -0.3px;
            color: #091635;
            margin: 0;
            line-height: 1.2;
        }

        .page-header-icon .material-symbols-rounded {
            font-size: 1.5rem;
        }

        .page-subtitle {
            font-size: 0.85rem;
            font-weight: 500;
            color: #8b97a8;
            margin-top: 0.2rem;
        }

        .messages-layout {
            display: flex;
            gap: 1.5rem;
            height: calc(100vh - 260px);
            min-height: 580px;
        }

        /* ── LEFT PANEL ── */
        .conversations-sidebar {
            background: #FFFFFF;
            border-radius: 18px;
            box-shadow: 0 12px 36px rgba(9, 22, 53, 0.08);
            border: 1px solid #eef2f7;
            width: 360px;
            min-width: 300px;
            overflow-y: auto;
            padding: 1.5rem 1.4rem;
            display: flex;
            flex-direction: column;
        }

        .conversations-header {
            display: flex;
            flex-direction: column;
            margin-bottom: 1.4rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #f0f4f8;
        }

        .conversations-title {
            font-size: 1.5rem;
            font-weight: 800;
            color: #091635;
            margin-bottom: 0.2rem;
            letter-spacing: -0.4px;
        }

        .conversations-subtitle {
            font-size: 0.82rem;
            color: #8b97a8;
            font-weight: 500;
            margin-bottom: 0;
        }

        .section-label {
            font-size: 0.72rem;
            font-weight: 700;
            color: #3d4f65;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            margin-bottom: 0.85rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .scroll-indicator {
            display: flex;
            align-items: center;
            color: #0D3C80;
        }

        .scroll-chevron {
            width: 26px;
            height: 26px;
            background: rgba(13, 60, 128, 0.08);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0D3C80;
            font-size: 16px;
            transition: background-color 0.2s ease, color 0.2s ease;
            cursor: pointer;
        }

        .scroll-chevron:hover {
            background: #0D3C80;
            color: #ffffff;
        }

        .matches-grid {
            display: flex;
            flex-direction: row;
            gap: 0.65rem;
            margin-bottom: 1.75rem;
            overflow-x: auto;
            overflow-y: hidden;
            padding-bottom: 0.5rem;
            scroll-behavior: smooth;
        }

        .matches-grid::-webkit-scrollbar { height: 6px; }
        .matches-grid::-webkit-scrollbar-track { background: transparent; }
        .matches-grid::-webkit-scrollbar-thumb { background: #d6dde6; border-radius: 3px; }
        .matches-grid::-webkit-scrollbar-thumb:hover { background: #b3c2d8; }

        .match-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-decoration: none;
            color: #5a6478;
            padding: 0.85rem 0.6rem;
            border-radius: 12px;
            transition: border-color 0.25s ease, background-color 0.25s ease, color 0.25s ease;
            background: #F8FAFC;
            border: 1.5px solid #eef2f7;
            min-width: 92px;
            flex-shrink: 0;
        }

        .match-item:hover {
            background: rgba(13, 60, 128, 0.05);
            border-color: rgba(13, 60, 128, 0.28);
            color: #0D3C80;
            text-decoration: none;
        }

        .match-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            object-fit: cover;
            border: 2.5px solid #ffffff;
            box-shadow: 0 0 0 1.5px #eef2f7;
            margin-bottom: 0.5rem;
            transition: box-shadow 0.25s ease;
        }

        .match-item:hover .match-avatar {
            box-shadow: 0 0 0 2px rgba(13, 60, 128, 0.4);
        }

        .match-name {
            font-size: 0.74rem;
            font-weight: 600;
            text-align: center;
            line-height: 1.25;
            max-width: 80px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .conversations-list { flex: 1; }

        .conversation-item {
            display: flex;
            align-items: center;
            padding: 0.85rem 0.85rem;
            margin-bottom: 0.4rem;
            border-radius: 12px;
            text-decoration: none;
            color: inherit;
            transition: background-color 0.2s ease, border-color 0.2s ease;
            border: 1.5px solid transparent;
        }

        .conversation-item:hover {
            background: #F8FAFC;
            border-color: #eef2f7;
            text-decoration: none;
        }

        .conversation-item.active {
            background: rgba(13, 60, 128, 0.06);
            border-color: rgba(13, 60, 128, 0.25);
        }

        .conversation-avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            object-fit: cover;
            margin-right: 0.85rem;
            border: 2px solid #ffffff;
            box-shadow: 0 0 0 1.5px #eef2f7;
        }

        .conversation-info {
            flex: 1;
            min-width: 0;
        }

        .conversation-name {
            font-weight: 700;
            color: #091635;
            font-size: 0.92rem;
            margin-bottom: 0.2rem;
            letter-spacing: -0.1px;
        }

        .conversation-preview {
            font-size: 0.78rem;
            color: #8b97a8;
            overflow: hidden;
            white-space: nowrap;
            text-overflow: ellipsis;
        }

        .conversation-meta {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 0.4rem;
        }

        .conversation-time {
            font-size: 0.72rem;
            color: #94A3B8;
            font-weight: 500;
            letter-spacing: 0.1px;
        }

        .unread-badge {
            background: linear-gradient(135deg, #0D3C80 0%, #071744 100%);
            color: white;
            border-radius: 999px;
            min-width: 20px;
            height: 20px;
            padding: 0 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.68rem;
            font-weight: 700;
            box-shadow: 0 2px 6px rgba(13, 60, 128, 0.28);
        }

        .no-items-message {
            text-align: center;
            padding: 2.5rem 1rem;
            color: #8b97a8;
            font-size: 0.85rem;
            margin-top: 2rem;
        }

        /* ── RIGHT PANEL ── */
        .chat-panel {
            background: #FFFFFF;
            border-radius: 18px;
            box-shadow: 0 12px 36px rgba(9, 22, 53, 0.08);
            border: 1px solid #eef2f7;
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .chat-header {
            padding: 1.15rem 1.5rem;
            border-bottom: 1px solid #f0f4f8;
            background: #ffffff;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .chat-user-info {
            display: flex;
            align-items: center;
            gap: 0.9rem;
        }

        .chat-avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #ffffff;
            box-shadow: 0 0 0 1.5px #eef2f7;
        }

        .chat-user-details h3 {
            font-size: 1.05rem;
            font-weight: 700;
            color: #091635;
            margin: 0;
            letter-spacing: -0.2px;
        }

        .chat-user-status {
            font-size: 0.78rem;
            color: #0D3C80;
            font-weight: 500;
        }

        .chat-actions { display: flex; gap: 0.5rem; }

        .chat-action-btn {
            width: 38px;
            height: 38px;
            border: 1.5px solid #eef2f7;
            background: #FFFFFF;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #5a6478;
            transition: border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
            cursor: pointer;
        }

        .chat-action-btn:hover {
            background: rgba(13, 60, 128, 0.05);
            border-color: rgba(13, 60, 128, 0.28);
            color: #0D3C80;
        }

        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 1.5rem 1.75rem;
            background: #fafbfd;
        }

        .message-day-divider {
            text-align: center;
            margin: 1.25rem 0 1.1rem;
            position: relative;
        }

        .message-day-divider::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 1px;
            background: #e2e8f0;
            z-index: 1;
        }

        .message-day-label {
            background: #ffffff;
            padding: 0.4rem 0.95rem;
            border-radius: 999px;
            font-size: 0.7rem;
            font-weight: 700;
            color: #6b7689;
            position: relative;
            z-index: 2;
            display: inline-block;
            border: 1px solid #eef2f7;
            letter-spacing: 0.4px;
            text-transform: uppercase;
        }

        .message-group { margin-bottom: 1.1rem; }

        .message-container {
            display: flex;
            margin-bottom: 0.3rem;
            align-items: flex-end;
            gap: 0.6rem;
        }

        .message-container.own { flex-direction: row-reverse; }

        .message-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            object-fit: cover;
            border: 1.5px solid #ffffff;
            box-shadow: 0 0 0 1.5px #eef2f7;
        }

        .message-bubble {
            max-width: 68%;
            padding: 0.75rem 1.05rem;
            border-radius: 16px;
            font-size: 0.9rem;
            line-height: 1.5;
            word-wrap: break-word;
        }

        .message-bubble.own {
            background: linear-gradient(135deg, #0D3C80 0%, #071744 100%);
            color: white;
            border-bottom-right-radius: 6px;
            box-shadow: 0 4px 14px rgba(13, 60, 128, 0.22);
        }

        .message-bubble.other {
            background: #FFFFFF;
            color: #1f2937;
            border: 1px solid #eef2f7;
            border-bottom-left-radius: 6px;
            box-shadow: 0 1px 2px rgba(9, 22, 53, 0.04);
        }

        .message-time {
            font-size: 0.7rem;
            color: #94A3B8;
            margin-top: 0.3rem;
            padding: 0 2.4rem;
            font-weight: 500;
        }

        .message-time.own {
            text-align: right;
        }

        .chat-input-area {
            padding: 1rem 1.5rem 1.25rem;
            background: #FFFFFF;
            border-top: 1px solid #f0f4f8;
        }

        .chat-input-container {
            display: flex;
            gap: 0.75rem;
            align-items: flex-end;
            background: #F8FAFC;
            border-radius: 14px;
            border: 1.5px solid #E2E8F0;
            padding: 0.7rem 0.85rem;
            transition: border-color 0.2s ease, background-color 0.2s ease, box-shadow 0.2s ease;
        }

        .chat-input-container:focus-within {
            border-color: #0D3C80;
            background: #FFFFFF;
            box-shadow: 0 0 0 3.5px rgba(13, 60, 128, 0.09);
        }

        .message-input {
            flex: 1;
            border: none;
            background: transparent;
            font-size: 0.9rem;
            font-family: 'Raleway', sans-serif;
            resize: none;
            min-height: 22px;
            max-height: 100px;
            line-height: 1.4;
            color: #091635;
            padding: 0.25rem 0.4rem;
        }

        .message-input:focus { outline: none; }
        .message-input::placeholder { color: #b4bfcc; }

        .input-actions {
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }

        .send-button {
            background: linear-gradient(135deg, #0D3C80 0%, #071744 100%);
            border: none;
            border-radius: 12px;
            width: 42px;
            height: 42px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.05rem;
            transition: box-shadow 0.2s ease, background 0.2s ease;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(13, 60, 128, 0.32);
        }

        .send-button:hover {
            background: linear-gradient(135deg, #1147a0 0%, #0D3C80 100%);
            box-shadow: 0 6px 18px rgba(13, 60, 128, 0.42);
        }

        .no-chat-selected {
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: #64748B;
            background: #fafbfd;
            flex: 1;
            padding: 2rem;
        }

        .no-chat-content {
            max-width: 420px;
        }

        .no-chat-icon {
            font-size: 2.2rem !important;
            color: #0D3C80;
            margin: 0 auto 1.25rem;
            width: 78px;
            height: 78px;
            border-radius: 20px;
            background: rgba(13, 60, 128, 0.08);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .no-chat-title {
            font-size: 1.2rem;
            font-weight: 700;
            color: #091635;
            margin-bottom: 0.45rem;
            letter-spacing: -0.2px;
        }

        .no-chat-subtitle {
            font-size: 0.88rem;
            color: #6b7689;
            line-height: 1.6;
        }

        /* Scrollbars */
        .conversations-sidebar::-webkit-scrollbar,
        .chat-messages::-webkit-scrollbar {
            width: 6px;
        }

        .conversations-sidebar::-webkit-scrollbar-track,
        .chat-messages::-webkit-scrollbar-track {
            background: transparent;
        }

        .conversations-sidebar::-webkit-scrollbar-thumb,
        .chat-messages::-webkit-scrollbar-thumb {
            background: #d6dde6;
            border-radius: 3px;
        }

        .conversations-sidebar::-webkit-scrollbar-thumb:hover,
        .chat-messages::-webkit-scrollbar-thumb:hover {
            background: #b3c2d8;
        }

        .client-name-link {
            text-decoration: none;
            color: #0D3C80;
            cursor: pointer;
            transition: color 0.2s ease;
        }

        .client-name-link:hover {
            color: #071744;
            text-decoration: underline;
        }

        /* ── CLIENT PROFILE MODAL ── */
        #clientProfileModal .modal-content {
            border-radius: 18px;
            border: 1px solid #e8edf5;
            box-shadow: 0 24px 64px rgba(9, 22, 53, 0.22);
            overflow: hidden;
        }

        #clientProfileModal .modal-content::before {
            content: '';
            display: block;
            height: 4px;
            background: linear-gradient(90deg, #0D3C80 0%, #071744 100%);
        }

        #clientProfileModal .modal-header {
            background: #ffffff;
            border-bottom: 1px solid #f0f4f8;
            padding: 1.25rem 1.75rem;
        }

        #clientProfileModal .modal-title {
            font-weight: 700;
            font-size: 1.05rem;
            color: #091635;
            letter-spacing: -0.2px;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        #clientProfileModal .modal-title i {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: rgba(13, 60, 128, 0.08);
            color: #0D3C80;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.95rem;
        }

        #clientProfileModal .btn-close {
            opacity: 0.55;
            transition: opacity 0.2s ease;
        }

        #clientProfileModal .btn-close:hover { opacity: 1; }

        #clientProfileModal .modal-body {
            padding: 1.75rem;
            background: #ffffff;
        }

        /* ── RESPONSIVE ── */
        @@media (max-width: 1200px) {
            .conversations-sidebar { width: 320px; min-width: 280px; }
        }

        @@media (max-width: 992px) {
            .messages-layout { flex-direction: column; height: auto; }
            .conversations-sidebar { width: 100%; max-height: 320px; }
            .chat-panel { min-height: 500px; }
        }

        @@media (max-width: 767.98px) {
            main.container {
                margin-left: 0 !important;
                margin-top: 100px;
                max-width: 100% !important;
                padding: 1rem;
                padding-top: 2rem;
            }

            .message-bubble { max-width: 85%; }
            .chat-messages { padding: 1rem; }
        }
    </style>
}

@section Scripts {
    <script>
        function insertMessageToChat(msg) {
            const chatContainer = document.getElementById("chat-container");

            if (!chatContainer) return;

            const bubble = document.createElement("div");
            bubble.classList.add("message-group");
            bubble.innerHTML = `
                <div class="message-container">
                    <img src="${msg.senderProfilePhoto}" class="message-avatar" />
                    <div class="message-bubble other">${msg.messageBody}</div>
                </div>
                <div class="message-time">${msg.messageDate}</div>
            `;

            chatContainer.appendChild(bubble);
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.querySelector('.sidebar');
            const sidebarToggler = document.querySelector('.sidebar-toggler');
            const mainContent = document.querySelector('main.container');

            function adjustMainContent() {
                if (sidebar && mainContent) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '85px';
                        mainContent.style.maxWidth = 'calc(100% - 85px)';
                    } else {
                        mainContent.style.marginLeft = '270px';
                        mainContent.style.maxWidth = 'calc(100% - 270px)';
                    }
                }
            }

            // Adjust on page load
            adjustMainContent();

            // Listen for sidebar toggle
            if (sidebarToggler) {
                sidebarToggler.addEventListener('click', function() {
                    setTimeout(adjustMainContent, 50);
                });
            }

            // Auto-scroll to bottom of chat
            const chatContainer = document.getElementById('chat-container');
            if (chatContainer) {
                chatContainer.scrollTop = chatContainer.scrollHeight;
            }

            // Auto-resize textarea and handle Enter key for sending
            const messageInput = document.querySelector('.message-input');
            if (messageInput) {
                // Auto-resize functionality
                messageInput.addEventListener('input', function() {
                    this.style.height = 'auto';
                    this.style.height = Math.min(this.scrollHeight, 100) + 'px';
                });

                // Handle Enter key to send message
                messageInput.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter' && !e.shiftKey) {
                        e.preventDefault(); // Prevent default line break behavior

                        // Check if there's text to send
                        const messageText = this.value.trim();
                        if (messageText) {
                            // Find the form and submit it
                            const form = this.closest('form');
                            if (form) {
                                form.submit();
                            }
                        }
                    }
                    // Allow Shift+Enter for line breaks
                });
            }

            // Scroll matches grid on chevron click
            const scrollChevron = document.querySelector('.scroll-chevron');
            const matchesGrid = document.querySelector('.matches-grid');
            if (scrollChevron && matchesGrid) {
                scrollChevron.addEventListener('click', () => {
                    matchesGrid.scrollBy({ left: 200, behavior: 'smooth' });
                });
            }
        });
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', async () => {

            const userId = '@User?.FindFirst("sub")?.Value';

            // ---------------------------
            // CONNECT TO NOTIFICATION HUB
            // ---------------------------
            const notifConnection = new signalR.HubConnectionBuilder()
                .withUrl("/notificationHub")
                .withAutomaticReconnect()
                .build();

            notifConnection.on("ReceiveNotification", () => {
                loadArchitectNotifications();
            });

            notifConnection.on("UpdateUnreadMessagesCount", () => {
                loadArchitectUnreadMessages();
            });

            await notifConnection.start()
                .then(() => console.log("NotificationHub connected (Architect Messages)"))
                .catch(err => console.error(err));


            // ---------------------
            // CONNECT TO CHAT HUB
            // ---------------------
            const chatConnection = new signalR.HubConnectionBuilder()
                .withUrl(`/chatHub?clientId=${userId}`)
                .withAutomaticReconnect()
                .build();

            chatConnection.on("ReceiveMessage", (data) => {
                console.log("Architect ReceivedMessage:", data);

                // If architect is currently viewing chat with this client → update chat UI instantly
                insertMessageToChat(data);

                // Update side panel unread count
                loadArchitectUnreadMessages();
            });

            chatConnection.on("UpdateUnreadMessagesCount", () => {
                loadArchitectUnreadMessages();
            });

            await chatConnection.start()
                .then(() => console.log("ChatHub connected (Architect Messages)"))
                .catch(err => console.error(err));

        });
    </script>3
    <script>
        $(document).on("click", "#openClientProfile", function () {
            const clientId = $(this).data("client-id");

            if (!clientId) return;

            $.ajax({
                url: "/ArchitectInterface/GetClientProfile",
                type: "GET",
                data: { clientId: clientId },
                success: function (res) {
                    if (!res.success) {
                        alert("Error: " + res.message);
                        return;
                    }

                    // Fill modal fields
                    $("#clientProfileName").text(res.name);
                    $("#clientProfileEmail").text(res.email || "No email");
                    $("#clientProfilePhone").text(res.phone || "No phone");
                    $(".profile-container img").attr("src", res.profilePhoto);

                    // Show modal
                    $("#clientProfileModal").modal("show");
                },
                error: function () {
                    alert("Failed to load client profile.");
                }
            });
        });
    </script>

}

<div>
    <div class="page-header">
        <div class="page-header-left">
            <div class="page-header-icon">
                <span class="material-symbols-rounded">chat_bubble</span>
            </div>
            <div>
                <h1 class="page-title">Messages</h1>
                <div class="page-subtitle">Connect with your clients</div>
            </div>
        </div>
    </div>

<div class="messages-layout">
    <!-- Left Panel - Conversations Sidebar -->
    <div class="conversations-sidebar">
        <!-- Matches Section -->
        @if (Model.Matches.Any())
        {
            <div class="section-label">
                <span>Available Matches</span>
                <div class="scroll-indicator">
                    <span class="material-symbols-rounded scroll-chevron">chevron_right</span>
                </div>
            </div>
            <div class="matches-grid">
                @foreach (var match in Model.Matches)
                {
                    var profilePhoto = string.IsNullOrEmpty(match.ClientProfileUrl)
                    ? "/images/default-profile.png"
                    : match.ClientProfileUrl.Replace("~", "").Replace("wwwroot", "");

                    <a asp-controller="ArchitectInterface"
                       asp-action="Messages"
                       asp-route-clientId="@match.ClientId"
                       class="match-item">
                        <img src="@profilePhoto" class="match-avatar" alt="@match.ClientName" />
                        <div class="match-name">@match.ClientName</div>
                    </a>
                }
            </div>
        }

        <!-- Conversations Section -->
        <div class="section-label">Recent Conversations</div>
        <div class="conversations-list">
            @if (Model.Conversations.Any())
            {
                @foreach (var convo in Model.Conversations)
                {
                    var convoPhoto = string.IsNullOrWhiteSpace(convo.ClientProfileUrl)
                    || convo.ClientProfileUrl.Contains("default", StringComparison.OrdinalIgnoreCase)
                    ? "/images/default-profile.png"
                    : convo.ClientProfileUrl.Replace("~", "").Replace("wwwroot", "");

                    <a asp-controller="ArchitectInterface"
                       asp-action="Messages"
                       asp-route-clientId="@convo.ClientId"
                       class="conversation-item @(Model.ActiveChat?.ClientId == convo.ClientId ? "active" : "")">
                        <img src="@convoPhoto" class="conversation-avatar" alt="@convo.ClientName" />
                        <div class="conversation-info">
                            <div class="conversation-name">@convo.ClientName</div>
                            <div class="conversation-preview">@(convo.LastMessage?.Length > 40 ? convo.LastMessage.Substring(0, 40) + "..." : convo.LastMessage)</div>
                        </div>
                        <div class="conversation-meta">
                            <div class="conversation-time">@convo.LastMessageTime.ToString("HH:mm")</div>
                            @if (convo.UnreadCount > 0)
                            {
                                <div class="unread-badge">@convo.UnreadCount</div>
                            }
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="no-items-message">No conversations yet</div>
            }
        </div>
    </div>

    <!-- Right Panel - Chat Area -->
    <div class="chat-panel">
        @if (Model.ActiveChat != null)
        {
            var chatPhoto = string.IsNullOrWhiteSpace(Model.ActiveChat.ClientProfileUrl)
            || Model.ActiveChat.ClientProfileUrl.Contains("default", StringComparison.OrdinalIgnoreCase)
            ? "/images/default-profile.png"
            : Model.ActiveChat.ClientProfileUrl.Replace("~", "").Replace("wwwroot", "");

            <!-- Chat Header -->
            <div class="chat-header">
                <div class="chat-user-info">
                    <img src="@chatPhoto" class="chat-avatar" alt="@Model.ActiveChat.ClientName" />

                    <div class="chat-user-details">
                        <h3>
                            <a href="javascript:void(0);"
                               id="openClientProfile"
                               data-client-id="@Model.ActiveChat.ClientId"
                               class="client-name-link">
                                @Model.ActiveChat.ClientName
                            </a>
                        </h3>
                    </div>
                </div>
            </div>

            <!-- Chat Messages -->
            <div class="chat-messages" id="chat-container">
                <div class="message-day-divider">
                    <span class="message-day-label">Today</span>
                </div>

                @foreach (var msg in Model.ActiveChat.Messages)
                {
                    var msgPhoto = string.IsNullOrWhiteSpace(msg.SenderProfilePhoto)
                    || msg.SenderProfilePhoto.Contains("default", StringComparison.OrdinalIgnoreCase)
                    ? "/images/default-profile.png"
                    : msg.SenderProfilePhoto.Replace("~", "").Replace("wwwroot", "");


                    <div class="message-group">
                        <div class="message-container @(msg.IsOwnMessage ? "own" : "")">
                            <img src="@msgPhoto" class="message-avatar" alt="Sender" />
                            <div class="message-bubble @(msg.IsOwnMessage ? "own" : "other")">
                                @msg.MessageBody
                            </div>
                        </div>
                        <div class="message-time @(msg.IsOwnMessage ? "own" : "")">
                            @msg.MessageDate.ToString("HH:mm")
                        </div>
                    </div>
                }
            </div>

            <!-- Chat Input -->
            <div class="chat-input-area">
                <form asp-controller="ArchitectInterface"
                      asp-action="SendMessage"
                      method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="clientId" value="@Model.ActiveChat.ClientId" />

                    <div class="chat-input-container">
                        <textarea name="messageBody" class="message-input" placeholder="Type your message..." rows="1"></textarea>
                        <div class="input-actions">
                            <button type="submit" class="send-button" title="Send Message">
                                <span class="material-symbols-rounded">send</span>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        }
        else
        {
            <div class="no-chat-selected">
                <div class="no-chat-content">
                    <div class="no-chat-icon material-symbols-rounded">chat</div>
                    <h2 class="no-chat-title">Welcome to Messages</h2>
                    <p class="no-chat-subtitle">Select a conversation from the sidebar to start chatting with your clients, or browse available matches to connect with new professionals.</p>
                </div>
            </div>
        }
    </div>
</div>
</div>

<!-- Client Profile Modal -->
<div class="modal fade" id="clientProfileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-user"></i>
                    Client Profile
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="profile-container">
                    <div class="profile-main-card p-3">
                        <div class="profile-info d-flex align-items-center gap-3 mb-3">
                            <div class="avatar">
                                <img src="~/images/profile.jpg" alt="Avatar" style="width:64px;height:64px;border-radius:50%;">
                            </div>
                            <div class="user-details">
                                <h3 id="clientProfileName" class="client-name mb-1 fw-bold"></h3>
                                <div id="clientProfileEmail" class="text-muted"></div>
                                <div id="clientProfilePhone" class="text-muted"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>