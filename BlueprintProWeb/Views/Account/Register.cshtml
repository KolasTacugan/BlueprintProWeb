@using BlueprintProWeb.ViewModels
@model RegisterViewModel

@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BlueprintPro</title>
    <link rel="icon" type="image/png" href="~/images/BBP Logo.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            font-family: 'Raleway', sans-serif;
        }

        body {
            margin: 0;
            padding: 20px;
            height: 100vh;
            overflow: hidden;
            background: linear-gradient(135deg, #e8edf5 0%, #d4dce9 100%);
            box-sizing: border-box;
        }

        .register-container {
            display: flex;
            height: calc(100vh - 40px);
            width: 100%;
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 24px 64px rgba(9, 22, 53, 0.22);
            position: relative;
        }

        /* ── LEFT PANEL ── */
        .register-left {
            flex: 1;
            position: relative;
            background: url("/images/bldg_img_1.png") center/cover no-repeat;
            overflow: hidden;
            clip-path: polygon(0 0, 85% 0, 70% 100%, 0 100%);
        }

        .left-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(
                170deg,
                rgba(7, 23, 68, 0.52) 0%,
                rgba(13, 60, 128, 0.22) 45%,
                rgba(7, 23, 68, 0.78) 100%
            );
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 3rem 3.5rem 4rem;
        }

        .left-brand-badge {
            width: 52px;
            height: 52px;
            background: rgba(255, 255, 255, 0.14);
            border: 1.5px solid rgba(255, 255, 255, 0.3);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.25rem;
            backdrop-filter: blur(8px);
            padding: 8px;
        }

        .left-brand-badge img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .left-brand-accent {
            width: 40px;
            height: 3px;
            background: linear-gradient(90deg, rgba(255,255,255,0.85), rgba(255,255,255,0.1));
            border-radius: 2px;
            margin-bottom: 1rem;
        }

        .left-brand-name {
            font-size: 2rem;
            font-weight: 800;
            color: #ffffff;
            letter-spacing: -0.5px;
            line-height: 1.15;
        }

        .left-brand-tagline {
            font-size: 0.88rem;
            color: rgba(255, 255, 255, 0.62);
            font-weight: 400;
            margin-top: 0.5rem;
            letter-spacing: 0.3px;
        }

        /* ── RIGHT PANEL ── */
        .register-right {
            flex: 1;
            background: #ffffff;
            margin-left: -10%;
            padding: 2rem;
            overflow-y: auto;
            height: 100%;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding-top: 2rem;
            position: relative;
        }

        .register-form-container {
            width: 100%;
            max-width: 540px;
            padding: 1rem 0;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        /* Custom scrollbar */
        .register-right::-webkit-scrollbar { width: 5px; }
        .register-right::-webkit-scrollbar-track { background: #f1f3f8; border-radius: 10px; }
        .register-right::-webkit-scrollbar-thumb { background: #b0c1d8; border-radius: 10px; }
        .register-right::-webkit-scrollbar-thumb:hover { background: #0D3C80; }

        .form-logo-badge {
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.25rem;
        }

        .form-logo-badge img {
            width: 80px;
            height: 80px;
            object-fit: contain;
        }

        .register-welcome {
            text-align: center;
            margin-bottom: 1.75rem;
        }

        .register-title {
            font-size: 2rem;
            font-weight: 800;
            color: #091635;
            margin-bottom: 0.35rem;
            letter-spacing: -0.5px;
        }

        .register-subtitle {
            color: #8b97a8;
            font-weight: 500;
            font-size: 0.88rem;
        }

        /* ── FORM LAYOUT ── */
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 0;
        }

        .form-col-full {
            grid-column: 1 / -1;
        }

        .mb-3 {
            margin-bottom: 1rem !important;
        }

        .form-label {
            font-weight: 700;
            color: #3d4f65;
            font-size: 0.75rem;
            letter-spacing: 0.55px;
            text-transform: uppercase;
            margin-bottom: 0.45rem;
            display: block;
        }

        /* ── INPUT WRAPPER WITH ICON ── */
        .input-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #c0ccd9;
            font-size: 0.82rem;
            pointer-events: none;
            transition: color 0.25s ease;
            z-index: 2;
        }

        .input-wrapper:focus-within .input-icon {
            color: #0D3C80;
        }

        .form-control {
            width: 100%;
            border: 1.5px solid #E2E8F0;
            border-radius: 10px;
            padding: 0.75rem 1rem;
            font-size: 0.9rem;
            transition: border-color 0.25s ease, box-shadow 0.25s ease, background 0.2s ease;
            background: #F8FAFC;
            color: #091635;
            outline: none;
        }

        .form-control::placeholder {
            color: #b4bfcc;
            font-weight: 400;
        }

        .form-control:hover {
            border-color: #b3c2d8;
            background: #ffffff;
        }

        .form-control:focus {
            border-color: #0D3C80;
            background: #ffffff;
            box-shadow: 0 0 0 3.5px rgba(13, 60, 128, 0.09);
        }

        /* Selects – no icon prefix */
        .form-select {
            width: 100%;
            border: 1.5px solid #E2E8F0;
            border-radius: 10px;
            padding: 0.75rem 2.5rem 0.75rem 1rem;
            font-size: 0.9rem;
            transition: border-color 0.25s ease, box-shadow 0.25s ease, background 0.2s ease;
            background-color: #F8FAFC;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23091635' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2 5l6 6 6-6'/%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 1rem center;
            background-size: 14px 14px;
            color: #091635;
            outline: none;
            appearance: none;
            -webkit-appearance: none;
            -moz-appearance: none;
        }

        .form-select:focus {
            border-color: #0D3C80;
            background-color: #ffffff;
            box-shadow: 0 0 0 3.5px rgba(13, 60, 128, 0.09);
        }

        /* ── ARCHITECT SECTION ── */
        .architect-section {
            background: rgba(13, 60, 128, 0.03);
            border: 1.5px solid rgba(13, 60, 128, 0.1);
            border-radius: 14px;
            padding: 1.5rem;
            margin: 1.25rem 0;
        }

        .architect-section-header {
            display: flex;
            align-items: center;
            gap: 0.65rem;
            margin-bottom: 1.25rem;
        }

        .architect-section-icon {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg, #0D3C80 0%, #071744 100%);
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            color: white;
            flex-shrink: 0;
        }

        .architect-section-title {
            color: #091635;
            font-weight: 700;
            font-size: 0.92rem;
            letter-spacing: 0.2px;
            margin: 0;
        }

        .architect-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .architect-grid .mb-3:first-child {
            grid-column: 1 / -1;
        }

        /* ── SUBMIT BUTTON ── */
        .register-btn {
            width: 100%;
            padding: 0.9rem;
            background: linear-gradient(135deg, #0D3C80 0%, #071744 100%);
            border: none;
            border-radius: 25px;
            color: white;
            font-weight: 700;
            font-size: 0.85rem;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            transition: all 0.3s ease;
            margin: 1.25rem 0;
            cursor: pointer;
        }

        .register-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(13, 60, 128, 0.38);
            background: linear-gradient(135deg, #1147a0 0%, #0D3C80 100%);
        }

        .register-btn:active {
            transform: translateY(0);
            box-shadow: 0 4px 12px rgba(13, 60, 128, 0.2);
        }

        /* ── BOTTOM LINKS ── */
        .login-link {
            text-align: center;
            margin-bottom: 0.75rem;
            font-size: 0.875rem;
            color: #7a8799;
        }

        .login-link a {
            color: #0D3C80;
            text-decoration: none;
            font-weight: 600;
        }

        .login-link a:hover {
            color: #071744;
            text-decoration: underline;
        }

        .back-link {
            text-align: center;
            margin-bottom: 2rem;
        }

        .back-link a {
            color: #9aaab8;
            text-decoration: none;
            font-weight: 500;
            font-size: 0.85rem;
            transition: color 0.2s;
        }

        .back-link a:hover {
            color: #0D3C80;
        }

        .text-danger {
            font-size: 0.78rem;
            margin-top: 0.3rem;
            display: block;
        }

        /* ── RESPONSIVE ── */
        @@media (max-width: 992px) {
            .form-row, .architect-grid {
                grid-template-columns: 1fr;
                gap: 0.5rem;
            }

            .architect-grid .mb-3:first-child {
                grid-column: 1;
            }
        }

        @@media (max-width: 768px) {
            body { padding: 10px; height: 100vh; }

            .register-container {
                flex-direction: column;
                height: calc(100vh - 20px);
            }

            .register-left {
                height: 25vh;
                flex: none;
                clip-path: polygon(0 0, 100% 0, 100% 85%, 0 95%);
            }

            .left-overlay {
                justify-content: center;
                align-items: center;
                text-align: center;
                padding: 2rem;
            }

            .left-brand-accent { margin: 0 auto 1rem; }

            .register-right {
                margin-left: 0;
                padding: 1.5rem;
                margin-top: -5%;
                padding-top: 8%;
                height: auto;
                flex: 1;
                align-items: flex-start;
            }

            .register-title { font-size: 1.75rem; }
            .architect-section { padding: 1rem; }
            .form-row, .architect-grid { grid-template-columns: 1fr; }
        }

        @@media (max-width: 480px) {
            body { padding: 5px; }

            .register-container {
                border-radius: 16px;
                height: calc(100vh - 10px);
            }

            .register-right { padding: 1rem; }
            .register-title { font-size: 1.6rem; }
            .register-form-container { max-width: 100%; }
        }
    </style>

    <div class="register-container">
        <!-- Left Side – Image with Brand Overlay -->
        <div class="register-left">
            <div class="left-overlay">
                <div class="left-brand-badge">
                    <img src="/images/BBP Logo.png" alt="BlueprintPro" />
                </div>
                <div class="left-brand-accent"></div>
                <div class="left-brand-name">BlueprintPro</div>
                <div class="left-brand-tagline">Connecting clients &amp; architects</div>
            </div>
        </div>

        <!-- Right Side – Register Form -->
        <div class="register-right">
            <div class="register-form-container">
                <div class="form-logo-badge">
                    <img src="/images/BBP Logo.png" alt="BlueprintPro" />
                </div>

                <div class="register-welcome">
                    <h2 class="register-title">Join Us</h2>
                    <p class="register-subtitle">Create your BlueprintPro account</p>
                </div>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <!-- Hidden Role (set from ChooseAccountType) -->
                    <input type="hidden" asp-for="Role" />

                    <!-- Common Fields in Two-Column Layout -->
                    <div class="form-row">
                        <div class="mb-3">
                            <label asp-for="FirstName" class="form-label"></label>
                            <div class="input-wrapper">
                                <input asp-for="FirstName" class="form-control" placeholder="e.g. Juan" />
                            </div>
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LastName" class="form-label"></label>
                            <div class="input-wrapper">
                                <input asp-for="LastName" class="form-control" placeholder="e.g. Dela Cruz" />
                            </div>
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <div class="input-wrapper">
                                <input asp-for="PhoneNumber" class="form-control"
                                       pattern="[0-9]{11}"
                                       maxlength="11"
                                       title="Please enter exactly 11 digits"
                                       placeholder="Enter 11-digit phone number"
                                       onkeypress="return isNumber(event)"
                                       oninput="validatePhoneNumber(this)" />
                            </div>
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <div class="input-wrapper">
                                <input asp-for="Email" class="form-control" placeholder="e.g. juan@example.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <div class="input-wrapper">
                                <input asp-for="Password" type="password" class="form-control" placeholder="Enter a strong password" />
                            </div>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label"></label>
                            <div class="input-wrapper">
                                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Re-enter your password" />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>

                    @if (Model.Role == "Architect")
                    {
                        <div class="architect-section">
                            <div class="architect-section-header">
                                <div class="architect-section-icon">
                                    <i class="fas fa-user-tie"></i>
                                </div>
                                <h4 class="architect-section-title">Architect Information</h4>
                            </div>

                            <div class="architect-grid">
                                <div class="mb-3">
                                    <label asp-for="LicenseNo" class="form-label"></label>
                                    <div class="input-wrapper">
                                        <input asp-for="LicenseNo" class="form-control" placeholder="e.g. ARC-2024-12345" />
                                    </div>
                                    <span asp-validation-for="LicenseNo" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Style" class="form-label">Preferred Style</label>
                                    <select asp-for="Style" class="form-select">
                                        <option value="">-- Select Style --</option>
                                        <option>Modern</option>
                                        <option>Traditional</option>
                                        <option>Contemporary</option>
                                        <option>Minimalist</option>
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Specialization" class="form-label">Specialization</label>
                                    <select asp-for="Specialization" class="form-select">
                                        <option value="">-- Select Specialization --</option>
                                        <option>Residential</option>
                                        <option>Commercial</option>
                                        <option>Industrial</option>
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Location" class="form-label">Location Availability</label>
                                    <select asp-for="Location" class="form-select">
                                        <option value="">-- Select Location --</option>
                                        <option>Urban</option>
                                        <option>Suburban</option>
                                        <option>Rural</option>
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="LaborCost" class="form-label">Labor Cost</label>
                                    <select asp-for="LaborCost" class="form-select">
                                        <option value="">-- Select Labor Cost --</option>
                                        <option>Low</option>
                                        <option>Medium</option>
                                        <option>High</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Submit -->
                    <input type="submit" value="Register" class="register-btn" />

                    <!-- Links -->
                    <div class="login-link">
                        Already have an account?
                        <a asp-controller="Account" asp-action="Login">Login</a>
                    </div>

                    <div class="back-link">
                        <a asp-controller="Account" asp-action="ChooseRole">Back</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial.cshtml");
        }

        <script>
            // Function to allow only numbers (0-9) on keypress
            function isNumber(event) {
                const charCode = (event.which) ? event.which : event.keyCode;
                // Allow backspace (8), delete (46), tab (9), escape (27), enter (13), and numbers (48-57)
                if (charCode === 8 || charCode === 9 || charCode === 27 || charCode === 13 ||
                    charCode === 46 || (charCode >= 48 && charCode <= 57)) {
                    return true;
                }
                return false;
            }

            // Function to validate phone number format
            function validatePhoneNumber(input) {
                // Remove any non-numeric characters
                input.value = input.value.replace(/[^0-9]/g, '');

                // Limit to 11 digits
                if (input.value.length > 11) {
                    input.value = input.value.substring(0, 11);
                }

                // Update validation display
                const isValid = input.value.length === 11;
                if (input.value.length > 0 && input.value.length !== 11) {
                    input.setCustomValidity("Phone number must be exactly 11 digits");
                } else {
                    input.setCustomValidity("");
                }
            }

            // Add form submission validation
            $(document).ready(function() {
                $('form').on('submit', function(e) {
                    const phoneInput = $('input[name="PhoneNumber"]');
                    const phoneValue = phoneInput.val();

                    if (phoneValue.length !== 11 || !/^\d{11}$/.test(phoneValue)) {
                        e.preventDefault();
                        alert('Please enter exactly 11 digits for the phone number.');
                        phoneInput.focus();
                        return false;
                    }
                });
            });
        </script>
    }
</body>
</html>
