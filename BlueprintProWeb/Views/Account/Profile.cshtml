@model BlueprintProWeb.ViewModels.ProfileViewModel
@{
    Layout = ViewData["Layout"]?.ToString();
    ViewData["Title"] = "Profile";
}

@section Styles {
    <style>
        body::before {
            background: url("/images/BPP_Dashboard_BG.png") center/cover no-repeat !important;
            opacity: 0.1 !important;
        }

        body {
            overflow-y: auto !important;
            height: auto !important;
            font-family: 'Raleway', sans-serif;
            background: #F1F7F9 !important;
        }

        main.container {
            margin-left: 300px;
            margin-top: 90px;
            padding-top: 1rem;
            padding-left: 2rem;
            padding-right: 2rem;
            padding-bottom: 2rem;
            max-width: calc(100% - 320px);
            transition: margin-left 0.4s ease, max-width 0.4s ease;
        }

        .sidebar.collapsed ~ * main.container,
        body:has(.sidebar.collapsed) main.container {
            margin-left: 110px;
            max-width: calc(100% - 130px);
        }

        /* ── Alert ──────────────────────────────── */
        .alert {
            padding: 14px 18px;
            margin-bottom: 20px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.875rem;
            border: none;
        }

        .alert-success {
            background: #eff8f1;
            color: #166534;
            border-left: 4px solid #22c55e;
        }

        .alert-danger {
            background: #fef2f2;
            color: #991b1b;
            border-left: 4px solid #ef4444;
        }

        /* ── Wrapper ────────────────────────────── */
        .profile-wrapper {
            width: 100%;
        }

        /* ── Main Card ──────────────────────────── */
        .profile-card {
            background: #ffffff;
            border-radius: 16px;
            border: 1px solid #eef2f7;
            box-shadow: 0 2px 20px rgba(7, 23, 68, 0.08);
            overflow: hidden;
        }

        /* ── Banner ─────────────────────────────── */
        .profile-banner {
            height: 130px;
            background: linear-gradient(135deg, #071744 0%, #1e3a8a 50%, #344EAD 100%);
            position: relative;
            display: flex;
            align-items: flex-start;
            justify-content: flex-end;
            padding: 20px 24px;
        }

        .profile-banner::after {
            content: "";
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
            pointer-events: none;
        }

        .banner-actions {
            display: flex;
            gap: 10px;
            position: relative;
            z-index: 1;
        }

        /* ── Edit / Action Buttons ──────────────── */
        .edit-btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(8px);
            color: #ffffff;
            border: 1px solid rgba(255, 255, 255, 0.3);
            padding: 9px 18px;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.2s ease;
            letter-spacing: 0.2px;
        }

        .edit-btn:hover {
            background: rgba(255, 255, 255, 0.28);
            color: #ffffff;
            text-decoration: none;
            transform: translateY(-1px);
        }

        /* ── Profile Body ───────────────────────── */
        .profile-body {
            padding: 44px 36px 36px;
        }

        /* ── Identity Row (Avatar + Name) ───────── */
        .profile-identity {
            display: flex;
            align-items: flex-end;
            gap: 24px;
            margin-bottom: 28px;
        }

        .avatar-container {
            flex-shrink: 0;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 4px solid #ffffff;
            overflow: hidden;
            background: #EBF1FD;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 16px rgba(7, 23, 68, 0.15);
            margin-top: -50px;
            cursor: pointer;
            transition: transform 0.2s ease;
        }

        .avatar-container:hover {
            transform: scale(1.04);
        }

        .avatar-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .avatar-initials {
            font-size: 34px;
            font-weight: 700;
            color: #344EAD;
            line-height: 1;
        }

        .identity-text {
            padding-bottom: 10px;
        }

        .profile-name {
            font-size: 1.6rem;
            font-weight: 700;
            color: #0f172a;
            margin: 0 0 10px;
            letter-spacing: -0.4px;
        }

        .role-badge {
            display: inline-flex;
            align-items: center;
            background: rgba(52, 78, 173, 0.08);
            color: #344EAD;
            padding: 4px 13px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            border: 1px solid rgba(52, 78, 173, 0.2);
        }

        /* ── Contact Row ────────────────────────── */
        .contact-row {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            padding: 18px 0;
            border-top: 1px solid #f0f4f8;
            border-bottom: 1px solid #f0f4f8;
            margin-bottom: 28px;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #475569;
            font-size: 0.875rem;
            font-weight: 500;
        }

        .ci-icon {
            width: 32px;
            height: 32px;
            background: rgba(52, 78, 173, 0.08);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #344EAD;
            font-size: 0.8rem;
            flex-shrink: 0;
        }

        /* ── Credentials ────────────────────────── */
        .credentials-section {
            margin-bottom: 28px;
        }

        .section-label {
            font-size: 0.7rem;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 14px;
        }

        .credentials-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 14px;
        }

        @@media (max-width: 1200px) {
            .credentials-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        .credential-card {
            background: #f8fafc;
            border: 1px solid #eef2f7;
            border-radius: 10px;
            padding: 14px 16px;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .credential-card:hover {
            border-color: rgba(52, 78, 173, 0.2);
            box-shadow: 0 2px 8px rgba(52, 78, 173, 0.06);
        }

        .credential-label {
            font-size: 0.68rem;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 5px;
        }

        .credential-value {
            font-size: 0.925rem;
            font-weight: 600;
            color: #1a202c;
        }

        .credentials-file-link {
            color: #344EAD;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s ease;
            font-size: 0.875rem;
        }

        .credentials-file-link:hover {
            color: #2563EB;
            text-decoration: none;
        }

        /* ── Help Section ───────────────────────── */
        .help-section {
            display: flex;
            align-items: center;
            gap: 10px;
            padding-top: 20px;
            border-top: 1px solid #f0f4f8;
            color: #64748b;
            font-size: 0.875rem;
        }

        .help-link {
            color: #344EAD;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: color 0.2s ease;
        }

        .help-link:hover {
            color: #2563EB;
            text-decoration: none;
        }

        /* ── Modal styles ───────────────────────── */
        .subscription-modal {
            display: none;
            position: fixed;
            z-index: 9999;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(7, 23, 68, 0.5);
            backdrop-filter: blur(4px);
        }

        .subscription-modal.show {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-content-medium {
            background: #ffffff;
            border-radius: 16px;
            padding: 0;
            margin: 20px;
            box-shadow: 0 20px 60px rgba(7, 23, 68, 0.2);
            border: 1px solid #eef2f7;
            max-width: 600px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            position: relative;
        }

        .modal-header-custom {
            background: linear-gradient(135deg, #071744 0%, #344EAD 100%);
            color: white;
            padding: 24px 28px;
            border-radius: 16px 16px 0 0;
            position: relative;
        }

        .modal-title-custom {
            font-size: 1.1rem !important;
            font-weight: 700;
            margin: 0;
        }

        .modal-subtitle {
            color: rgba(255, 255, 255, 0.75);
            font-size: 0.875rem;
            margin-top: 4px;
            font-weight: 400;
        }

        .modal-close {
            position: absolute;
            top: 16px;
            right: 20px;
            background: rgba(255, 255, 255, 0.15);
            border: none;
            color: white;
            font-size: 1.25rem;
            cursor: pointer;
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s ease;
        }

        .modal-close:hover {
            background: rgba(255, 255, 255, 0.25);
        }

        .modal-body-custom {
            padding: 24px 28px;
        }

        .purchased-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .purchased-item {
            display: flex;
            align-items: center;
            background: #f8fafc;
            border-radius: 10px;
            padding: 12px 14px;
            border: 1px solid #eef2f7;
            transition: all 0.2s ease;
            cursor: pointer;
        }

        .purchased-item:hover {
            border-color: rgba(52, 78, 173, 0.2);
            box-shadow: 0 2px 10px rgba(52, 78, 173, 0.08);
        }

        .purchased-image {
            width: 52px;
            height: 52px;
            object-fit: cover;
            border-radius: 8px;
            margin-right: 14px;
            border: 1px solid #eef2f7;
            flex-shrink: 0;
        }

        .purchased-details h5 {
            margin: 0 0 3px;
            color: #0f172a;
            font-size: 0.9rem;
            font-weight: 600;
        }

        .purchased-details p {
            margin: 0;
            color: #64748b;
            font-size: 0.8rem;
        }

        .purchased-price {
            color: #344EAD !important;
            font-weight: 600 !important;
        }

        /* Blueprint details modal */
        .blueprint-details-modal {
            background: #ffffff;
            border-radius: 16px;
            max-width: 460px;
            width: 90%;
            max-height: 75vh;
            overflow-y: auto;
            box-shadow: 0 20px 60px rgba(7, 23, 68, 0.2);
            border: 1px solid #eef2f7;
        }

        .blueprint-details-header {
            background: linear-gradient(135deg, #071744 0%, #344EAD 100%);
            color: white;
            padding: 20px 24px;
            border-radius: 16px 16px 0 0;
            position: relative;
        }

        .blueprint-details-body {
            padding: 20px 24px;
        }

        .blueprint-details-image {
            width: 100%;
            height: 160px;
            object-fit: cover;
            border-radius: 10px;
            margin-bottom: 14px;
            border: 1px solid #eef2f7;
        }

        .blueprint-details-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 6px;
        }

        .blueprint-details-price {
            font-size: 0.95rem;
            font-weight: 700;
            color: #344EAD;
            margin-bottom: 12px;
        }

        .blueprint-details-description {
            color: #475569;
            line-height: 1.6;
            margin-bottom: 12px;
            font-size: 0.875rem;
        }

        .blueprint-details-architect {
            font-weight: 600;
            color: #344EAD;
            font-size: 0.875rem;
        }

        /* ── Responsive ─────────────────────────── */
        @@media (max-width: 767.98px) {
            main.container {
                margin-left: 0 !important;
                max-width: 100% !important;
                padding: 1rem;
                padding-top: 5rem;
            }

            .credentials-grid {
                grid-template-columns: 1fr;
            }

            .contact-row {
                flex-direction: column;
                gap: 10px;
            }

            .profile-identity {
                flex-direction: column;
                align-items: flex-start;
            }

            .banner-actions {
                flex-direction: column;
                align-items: flex-end;
            }
        }
    </style>
}

<div class="profile-wrapper">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="profile-card">

        <!-- Banner -->
        <div class="profile-banner">
            <div class="banner-actions">
                <a asp-controller="Account" asp-action="EditProfile" class="edit-btn">
                    <i class="fas fa-edit"></i> Edit Profile
                </a>
                @if (Model.Role == "Client")
                {
                    <button class="edit-btn" onclick="openPurchasedBlueprintsModal()">
                        <i class="fas fa-shopping-bag"></i> Purchased
                    </button>
                }
            </div>
        </div>

        <!-- Body -->
        <div class="profile-body">

            <!-- Identity -->
            <div class="profile-identity">
                <div class="avatar-container">
                    @if (!string.IsNullOrEmpty(Model.ProfilePhoto))
                    {
                        <img src="@Url.Content(Model.ProfilePhoto)" alt="@Model.FullName">
                    }
                    else
                    {
                        <span class="avatar-initials">
                            @(Model.FirstName?.Substring(0, 1).ToUpper())@(Model.LastName?.Substring(0, 1).ToUpper())
                        </span>
                    }
                </div>
                <div class="identity-text">
                    <h3 class="profile-name">@Model.FullName</h3>
                    <span class="role-badge">@Model.Role</span>
                </div>
            </div>

            <!-- Contact -->
            <div class="contact-row">
                <div class="contact-item">
                    <span class="ci-icon"><i class="fas fa-envelope"></i></span>
                    <span>@Model.Email</span>
                </div>
                <div class="contact-item">
                    <span class="ci-icon"><i class="fas fa-phone"></i></span>
                    <span>@(Model.PhoneNumber ?? "No phone number")</span>
                </div>
            </div>

            @* Architect credentials *@
            @if (Model.Role == "Architect")
            {
                <div class="credentials-section">
                    <div class="section-label">Professional Credentials</div>
                    <div class="credentials-grid">
                        @if (!string.IsNullOrEmpty(Model.LicenseNo))
                        {
                            <div class="credential-card">
                                <div class="credential-label">License No</div>
                                <div class="credential-value">@Model.LicenseNo</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Style))
                        {
                            <div class="credential-card">
                                <div class="credential-label">Style</div>
                                <div class="credential-value">@Model.Style</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Specialization))
                        {
                            <div class="credential-card">
                                <div class="credential-label">Specialization</div>
                                <div class="credential-value">@Model.Specialization</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Location))
                        {
                            <div class="credential-card">
                                <div class="credential-label">Location</div>
                                <div class="credential-value">@Model.Location</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Budget))
                        {
                            <div class="credential-card">
                                <div class="credential-label">Budget Range</div>
                                <div class="credential-value">@Model.Budget</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.CredentialsFilePath))
                        {
                            <div class="credential-card">
                                <div class="credential-label">Credentials File</div>
                                <div class="credential-value">
                                    <a href="@Url.Content($"~/credentials/{Model.CredentialsFilePath}")"
                                       target="_blank"
                                       class="credentials-file-link">
                                        <i class="fas fa-file-pdf"></i> @Model.CredentialsFilePath
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Help -->
            <div class="help-section">
                <span class="ci-icon"><i class="fas fa-download"></i></span>
                <span>Need help? Download the guide:</span>
                @if (Model.Role == "Architect")
                {
                    <a href="~/uploads/ARCHITECT USER GUIDE.pdf" download class="help-link">
                        <i class="fas fa-file-pdf"></i> Architect User Guide
                    </a>
                }
                else
                {
                    <a href="~/uploads/CLIENT USER GUIDE.pdf" download class="help-link">
                        <i class="fas fa-file-pdf"></i> Client User Guide
                    </a>
                }
            </div>

        </div>
    </div>

    <!-- Hidden upload form -->
    <form asp-action="UploadProfilePicture" method="post" enctype="multipart/form-data" style="display: none;">
        <input type="file" id="profilePictureInput" name="ProfilePicture" accept="image/*" onchange="uploadProfilePicture(this)" class="file-input" />
    </form>
</div>

<!-- PURCHASED BLUEPRINTS MODAL -->
<div id="purchasedBlueprintsModal" class="subscription-modal">
    <div class="modal-content-medium">
        <div class="modal-header-custom">
            <button class="modal-close" onclick="closePurchasedBlueprintsModal()">&times;</button>
            <h2 class="modal-title-custom">Your Purchased Blueprints</h2>
            <p class="modal-subtitle">Blueprints you have purchased from the marketplace</p>
        </div>
        <div class="modal-body-custom">
            <div id="purchasedBlueprintsContainer">
                <div class="text-center py-4">
                    <i class="fas fa-spinner fa-spin fa-2x text-muted"></i>
                    <p class="mt-2 text-muted">Loading your purchased blueprints...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- BLUEPRINT DETAILS MODAL -->
<div id="blueprintDetailsModal" class="subscription-modal">
    <div class="blueprint-details-modal">
        <div class="blueprint-details-header">
            <button class="modal-close" onclick="closeBlueprintDetailsModal()">&times;</button>
            <h2 class="modal-title-custom">Blueprint Details</h2>
        </div>
        <div class="blueprint-details-body" id="blueprintDetailsContent"></div>
    </div>
</div>

@section Scripts {
    <script>
        // SIDEBAR ADJUSTMENT
        document.addEventListener('DOMContentLoaded', function () {
            const sidebar = document.querySelector('.sidebar');
            const sidebarToggler = document.querySelector('.sidebar-toggler');
            const mainContent = document.querySelector('main.container');

            function adjustMainContent() {
                if (sidebar && mainContent) {
                    if (sidebar.classList.contains('collapsed')) {
                        mainContent.style.marginLeft = '110px';
                        mainContent.style.maxWidth = 'calc(100% - 130px)';
                    } else {
                        mainContent.style.marginLeft = '300px';
                        mainContent.style.maxWidth = 'calc(100% - 320px)';
                    }
                }
            }

            adjustMainContent();

            if (sidebarToggler) {
                sidebarToggler.addEventListener('click', function () {
                    setTimeout(adjustMainContent, 50);
                }); 
            }
        });

        // PROFILE PICTURE UPLOAD
        function uploadProfilePicture(input) {
            const file = input.files[0];
            if (!file) return;

            if (file.size > 5 * 1024 * 1024) {
                alert('File size must be less than 5MB');
                input.value = '';
                return;
            }

            const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif'];
            if (!allowedTypes.includes(file.type)) {
                alert('Please select a valid image file (JPG, PNG, or GIF)');
                input.value = '';
                return;
            }

            input.form.submit();
        }

        // PURCHASED BLUEPRINTS MODAL
        function openPurchasedBlueprintsModal() {
            document.getElementById('purchasedBlueprintsModal').classList.add('show');
            document.body.style.overflow = 'hidden';
            loadPurchasedBlueprints();
        }

        function closePurchasedBlueprintsModal() {
            document.getElementById('purchasedBlueprintsModal').classList.remove('show');
            document.body.style.overflow = 'auto';
        }

        async function loadPurchasedBlueprints() {
            try {
                const response = await fetch('/ClientInterface/GetPurchasedBlueprints');
                const blueprints = await response.json();
                const container = document.getElementById('purchasedBlueprintsContainer');

                if (blueprints.length === 0) {
                    container.innerHTML = `
                        <div class="text-center py-4">
                            <i class="fas fa-shopping-bag fa-3x text-muted"></i>
                            <h5 class="mt-3" style="color:#0f172a;">No Purchased Blueprints</h5>
                            <p class="text-muted" style="font-size:0.875rem;">You haven't purchased any blueprints yet.</p>
                            <a href="/ClientInterface/BlueprintMarketplace" class="edit-btn" style="background:#344EAD;border:none;margin-top:8px;display:inline-flex;">Browse Marketplace</a>
                        </div>`;
                    return;
                }

                let html = '<div class="purchased-list">';
                blueprints.forEach(bp => {
                    const imageUrl = bp.image ? `/images/${bp.image}` : '/images/default-blueprint.png';
                    html += `
                        <div class="purchased-item" onclick="openBlueprintDetailsModal(${bp.id})">
                            <img src="${imageUrl}" alt="${bp.name}" class="purchased-image">
                            <div class="purchased-details">
                                <h5>${bp.name}</h5>
                                <p>Style: ${bp.style || 'N/A'}</p>
                                <p class="purchased-price">₱${bp.price}</p>
                            </div>
                        </div>`;
                });
                html += '</div>';
                container.innerHTML = html;
            } catch (error) {
                document.getElementById('purchasedBlueprintsContainer').innerHTML = `
                    <div class="text-center py-4">
                        <i class="fas fa-exclamation-triangle fa-3x text-danger"></i>
                        <h5 class="mt-3">Error Loading Blueprints</h5>
                        <p class="text-muted">Please try again later.</p>
                    </div>`;
            }
        }

        // BLUEPRINT DETAILS MODAL
        async function openBlueprintDetailsModal(blueprintId) {
            try {
                const response = await fetch(`/ClientInterface/GetBlueprintDetails?id=${blueprintId}`);
                const blueprint = await response.json();
                const imageUrl = blueprint.image ? `/images/${blueprint.image}` : '/images/default-blueprint.png';

                document.getElementById('blueprintDetailsContent').innerHTML = `
                    <img src="${imageUrl}" alt="${blueprint.name}" class="blueprint-details-image">
                    <h3 class="blueprint-details-title">${blueprint.name}</h3>
                    <p class="blueprint-details-price">₱${blueprint.price}</p>
                    <p class="blueprint-details-description">${blueprint.description || 'No description available.'}</p>
                    <p class="blueprint-details-architect">Architect: ${blueprint.architectName || 'Unknown'}</p>`;

                document.getElementById('blueprintDetailsModal').classList.add('show');
                document.body.style.overflow = 'hidden';
            } catch (error) {
                alert('Failed to load blueprint details.');
            }
        }

        function closeBlueprintDetailsModal() {
            document.getElementById('blueprintDetailsModal').classList.remove('show');
            document.body.style.overflow = 'auto';
        }

        document.addEventListener('click', function (e) {
            const purchasedModal = document.getElementById('purchasedBlueprintsModal');
            if (e.target === purchasedModal) closePurchasedBlueprintsModal();
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                closePurchasedBlueprintsModal();
                closeBlueprintDetailsModal();
            }
        });
    </script>
}
